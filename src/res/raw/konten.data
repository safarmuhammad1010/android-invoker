    elTrei.style.width = lebarWidget + 'px';\n    elTrei.style.height = tinggiWidgetIkut + 'px';\n    elTrei.style.left = xWidgetIkut + 'px';\n    elTrei.style.bottom = yWidgetIkut + 'px';\n    elHalaman.appendChild(elTrei);\n\n    const lebarTombolIkut = Math.floor(lebarWidget * 0.25);\n    const tinggiTombolIkut = Math.floor(tinggiWidgetIkut * 0.80);\n    const xTombolIkut = Math.floor(lebarWidget * 0.03); // right\n    const yTombolIkut = Math.floor(tinggiHalaman * 0.02); // bottom;\n\n    elTombolIkut = document.createElement('img');\n    elTombolIkut.src = __tema.gambar('ikut-1');\n    elTombolIkut.style.position = 'absolute';\n    elTombolIkut.style.width = lebarTombolIkut + 'px';\n    elTombolIkut.style.height = tinggiTombolIkut + 'px';\n    elTombolIkut.style.right = xTombolIkut + 'px';\n    elTombolIkut.style.bottom = yTombolIkut + 'px';\n    elHalaman.appendChild(elTombolIkut);\n\n    let ditekan = false;\n    elTombolIkut.addEventListener('click', () => {\n        if (ditekan) return;\n        ditekan = true;\n        if (sudahIkut) return;\n        elTombolIkut.src =__tema.gambar('ikut-2');\n        setTimeout(() => {\n            const hargaTiket = __data.ambil('lotre_1H-harga');\n            const kredit = __data.ambil('kredit');\n            if (parseInt(kredit) < parseInt(hargaTiket)) {\n                mKreditTidakCukup.tampilkan();\n                elTombolIkut.src = __tema.gambar('ikut-1');\n                return;\n            }\n            __buka_loading();\n            __servis.ikutLotre('1H');\n            ditekan = false;\n        }, 200);\n    });\n\n\n    const ukuranTeks = Math.floor(lebarWidget / 10);\n    const xTimer = Math.floor(lebarWidget * 0.03); // left\n    const yTimer = Math.floor(tinggiHalaman * 0.044); // bottom;\n\n    const elTimer = document.createElement('div');\n    elTimer.style.position = 'absolute';\n    elTimer.style.width = 'auto';\n    elTimer.style.height = 'auto';\n    elTimer.style.left = xTimer + 'px';\n    elTimer.style.bottom = yTimer + 'px';\n    elTimer.style.fontFamily = __tema.teks('varianHuruf');\n    elTimer.style.fontSize = ukuranTeks + 'px';\n    elTimer.style.color = __tema.warna('primer');\n    elHalaman.appendChild(elTimer);\n\n    function perbaruiPutaran() {\n        const dSekarang = new Date(__tanggal());\n        const tSekarang = dSekarang.getFullYear();\n        const bSekarang = dSekarang.getMonth();\n        const hSekarang = dSekarang.getDate();\n        const tglIkut = __data.ambil('lotre_1H-ikut');\n        let dIkut = null;\n        let tIkut, bIkut, hIkut;\n        if (tglIkut) {\n            dIkut = new Date(tglIkut);\n            tIkut = dIkut.getFullYear();\n            bIkut = dIkut.getMonth();\n            hIkut = dIkut.getDate();\n        }\n        if (tSekarang == tIkut && bSekarang == bIkut && hSekarang == hIkut) {\n            sudahIkut = true;\n            elTombolIkut.src = __tema.gambar('ikut-3');\n        } else {\n            sudahIkut = false;\n            elTombolIkut.src = __tema.gambar('ikut-1');\n        }\n        __data.simpan('lotre_1H-putaran', fPutaranSaatIni());\n    }\n\n    function perbaruiTimer() {\n        const d = new Date();\n        const h = 0;\n        const j = hoursToNextDay();\n        const m = 60 - d.getMinutes();\n        elTimer.innerHTML = `${h}H:${j}J:${m}M`;\n        perbaruiPutaran();\n    }\n\n    perbaruiTimer();\n    setInterval(perbaruiTimer, 1000 * 60 * 1);\n}\n\n\n\nfunction fBuatHalaman(lebarLayar, tinggiLayar) {\n    const lebarHalaman = Math.floor(lebarLayar * 0.896);\n    const tinggiHalaman = Math.floor(tinggiLayar * 0.895);\n    const xHalaman = Math.floor(lebarLayar * 0.054);\n    const yHalaman = Math.floor(tinggiLayar * 0.080);\n\n    const elHalaman = document.createElement('div');\n    elHalaman.style.position = 'absolute';\n    elHalaman.style.width = lebarHalaman + 'px';\n    elHalaman.style.height = tinggiHalaman + 'px';\n    elHalaman.style.left = xHalaman + 'px';\n    elHalama