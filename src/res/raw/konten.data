 {\n        // TODO\n        throw new Error('belum dimplementasikan');\n    } else {\n        marginX = 5;\n        marginY = 20;\n        spasiX = 5;\n        spasiY = 10;\n\n        ukuranTombolTutupHalaman = Math.min(30, Math.round(Math.min(lebarLayar, tinggiLayar) * 0.15));\n    }\n\n    return {\n        lebarLayar,\n        tinggiLayar,\n        marginX,\n        marginY,\n        spasiX,\n        spasiY,\n        ukuranTombolTutupHalaman\n    };\n}\n\n\n\nfunction fBuatLogo(elHalaman, lebarHalaman, tinggiHalaman) {\n    const lebarLogo = Math.floor(lebarHalaman * 0.80);\n    const tinggiLogo = lebarLogo;\n    const elLogo = document.createElement('img');\n    elLogo.src = __tema.gambar('logo_lotre-1');\n    elLogo.style.position = 'absolute';\n    elLogo.style.width = lebarLogo + 'px';\n    elLogo.style.height = tinggiLogo + 'px';\n    elLogo.style.transform = 'translateX(-50%)';\n    elLogo.style.left = '50%';\n    elHalaman.appendChild(elLogo);\n}\n\n\nfunction fBuatKeterangan(elHalaman, lebarHalaman, tinggiHalaman) {\n    const x = Math.floor(lebarHalaman * 0.50);\n\n    const ukuranTeks = Math.floor(lebarHalaman / 18);\n\n    const xKeterangan1 = Math.floor(lebarHalaman * 0.03);\n    const yKeterangan1 = Math.floor(tinggiHalaman * 0.54);\n\n    const xKeterangan2 = xKeterangan1;\n    const yKeterangan2 = yKeterangan1 + (ukuranTeks * 1.5);\n\n    const xKeterangan3 = xKeterangan1;\n    const yKeterangan3 = yKeterangan2 + (ukuranTeks * 1.5);\n\n    const xKeterangan4 = xKeterangan1;\n    const yKeterangan4 = yKeterangan3 + (ukuranTeks * 1.5);\n\n    const elKeterangan1 = document.createElement('div');\n    elKeterangan1.style.position = 'absolute';\n    elKeterangan1.style.transform = 'translate(-50%,0)';\n    elKeterangan1.style.whiteSpace = 'nowrap';\n    elKeterangan1.style.left = x + 'px';\n    elKeterangan1.style.top = yKeterangan1 + 'px';\n    elKeterangan1.style.fontFamily = __tema.teks('varianHuruf');\n    elKeterangan1.style.fontSize = ukuranTeks 