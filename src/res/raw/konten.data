y + 'px';\n        }\n    };\n}\n\n\n__ekspor('buat', fBuat);\n"}, "profil.data": {"modul/profil.data/index.js": "\n\nfunction fBuatFotoProfil(elKontener, ukuran) {\n    const gambarFotoProfilBawaan = __tema.gambar('foto_profil');\n\n    const elLatar = document.createElement('img');\n    elLatar.src = __tema.gambar('profil.latar_foto');\n    elLatar.style.position = 'absolute';\n    elLatar.style.width = ukuran.lebarLatarFotoProfil + 'px';\n    elLatar.style.height = ukuran.tinggiLatarFotoProfil + 'px';\n    elLatar.style.left = ukuran.xLatarFotoProfil + 'px';\n    elLatar.style.top = ukuran.yLatarFotoProfil + 'px';\n    elKontener.appendChild(elLatar);\n\n    const elFotoProfil = document.createElement('img');\n    elFotoProfil.style.position = 'absolute';\n    elFotoProfil.style.width = ukuran.lebarKontenFotoProfil + 'px';\n    elFotoProfil.style.height = ukuran.tinggiKontenFotoProfil + 'px';\n    elFotoProfil.style.left = ukuran.xKontenFotoProfil + 'px';\n    elFotoProfil.style.top = ukuran.yKontenFotoProfil + 'px';\n    elFotoProfil.src = gambarFotoProfilBawaan;\n    elKontener.appendChild(elFotoProfil);\n\n    __data.pantau('profil.foto', (_, link) => {\n        console.info('mengatur foto profil: ', link);\n        if (! link) {\n            elFotoProfil.src = gambarFotoProfilBawaan;\n        } else {\n            elFotoProfil.src = link;\n        }\n    });\n}\n\n\nfunction fBuatKolomGender(elKontener, ukuran) {\n    const elLatar = document.createElement('img');\n    elLatar.style.position = 'absolute';\n    elLatar.style.width = ukuran.lebarLatarGender + 'px';\n    elLatar.style.height = ukuran.tinggiLatarGender + 'px';\n    elLatar.style.left = ukuran.xLatarGender + 'px';\n    elLatar.style.top = ukuran.yLatarGender + 'px';\n    elKontener.appendChild(elLatar);\n\n    const gambarGenderPria = __impor('aset/gambar/gender-pria.png');\n    const gambarGenderWanita = __impor('aset/gambar/gender-wanita.png');\n\n    __data.pantau('profil.gender', (_, gender) =