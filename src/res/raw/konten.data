laman harus_login-dalam...');\n\n\n\nconst mSkroller =  __impor('modul/0skroller');\n\n\n\n\nconst el = document.createElement('div');\ndocument.body.appendChild(el);\n\n\n\n\n\nfunction fAturTrei(lebarLayar, tinggiLayar) {\n    const gambarTreiAtas = __tema.gambar('trei-atas-3');\n    const gambarTreiTengah1 = __tema.gambar('trei-tengah-1');\n    const gambarTreiTengah2 = __tema.gambar('trei-tengah-2');\n    const gambarTreiBawah = __tema.gambar('trei-bawah-1');\n\n    const elTrei = document.createElement('div');\n    elTrei.style.position = 'absolute';\n    elTrei.style.top = '0';\n    elTrei.style.left = '0';\n    elTrei.style.width = '100%';\n    elTrei.style.height = '100%';\n    elTrei.style.margin = '0';\n    elTrei.style.padding = '0';\n\n    const elTreiAtas = document.createElement('img');\n    elTreiAtas.src = gambarTreiAtas;\n    elTreiAtas.style.display = 'block';\n    elTreiAtas.style.width = '100%';\n    elTreiAtas.style.height = '15%';\n    elTreiAtas.style.margin = '0';\n    elTrei.appendChild(elTreiAtas);\n\n    const elTreiTengah1 = document.createElement('img');\n    elTreiTengah1.src = gambarTreiTengah1;\n    elTreiTengah1.style.display = 'block';\n    elTreiTengah1.style.width = '100%';\n    elTreiTengah1.style.height = '35%';\n    elTreiTengah1.style.margin = '0';\n    elTrei.appendChild(elTreiTengah1);\n\n    const elTreiTengah2 = document.createElement('img');\n    elTreiTengah2.src = gambarTreiTengah2;\n    elTreiTengah2.style.display = 'block';\n    elTreiTengah2.style.width = '100%';\n    elTreiTengah2.style.height = '35%';\n    elTreiTengah2.style.margin = '0';\n    elTrei.appendChild(elTreiTengah2);\n\n    const elTreiBawah = document.createElement('img');\n    elTreiBawah.src = gambarTreiBawah;\n    elTreiBawah.style.display = 'block';\n    elTreiBawah.style.width = '100%';\n    elTreiBawah.style.height = '15%';\n    elTreiBawah.style.margin = '0';\n    elTrei.appendChild(elTreiBawah);\n\n    el.prepend(elTrei);\n}\n\n\n\nfunction fAturTombolLogin(lebarLayar, tinggiLayar) {\n    const gambarNormal = __tema.gambar('tombol-login-1');\n    const gambarDitekan = __tema.gambar('tombol-login-2');\n\n    const elTombolLogin = document.createElement('img');\n    elTombolLogin.style.position = 'absolute';\n    elTombolLogin.style.width = '40%';\n    elTombolLogin.style.height = '6%';\n    elTombolLogin.style.transform = 'translate(-50%, 0)';\n    elTombolLogin.style.left = '50%';\n    elTombolLogin.style.top = '92%';\n    elTombolLogin.src = gambarNormal;\n    el.appendChild(elTombolLogin);\n\n    elTombolLogin.addEventListener('click', () => {\n        elTombolLogin.src = gambarDitekan;\n        setTimeout(() => {\n            elTombolLogin.src = gambarNormal;\n            fSembunyikan();\n            __harus_login__tampilkanHalInputNama(fTampilkan);\n        }, 200);\n    });\n}\n\n\n\n\nfunction fBuatSkroller(elKontener, lebarKontener, tinggiKontener) {\n    const oSkroller = mSkroller.buat(lebarKontener, tinggiKontener);\n    elKontener.appendChild(oSkroller.kontener());\n    return oSkroller.konten();\n}\n\n\n\nfunction fBuatKonten(elKonten, lebarHalaman, tinggiHalaman) {\n    const ukuranHurufTeks = __tema.teks('ukuranHuruf');\n    const ukuranHurufJudul = ukuranHurufTeks * 2;\n\n    const elJudul = document.createElement('div');\n    elJudul.style.fontSize = ukuranHurufJudul + 'px';\n    elJudul.style.fontFamily = __tema.teks('varianHuruf');\n    elJudul.style.color = __tema.warna('error');\n    elJudul.style.textAlign = 'center';\n    elJudul.innerHTML = 'LOGIN DIPERLUKAN';\n    elKonten.appendChild(elJudul);\n\n    const teks = `\n[1] Ini bisa terjadi karena anda login di perangkat lain.\n<br/>\n[2] Jika anda merasa tidak pernah login di perangkat lain, maka silahkan lakukan reset kata sandi.\n<br/>\n[3] Untuk melakukan reset kata sandi, silhkan hubungi: admininvoker1@gmail.com\n`;\n\n    const elTeks = document.createElement('div');\n    elTeks.style.fontSize = ukuranHurufTeks + 'px';\n    elTeks.style.fontFamily = __tema.teks('varianHuruf');\n    elTeks.style.color = __tema.warna('tips');\n    elTeks.style.textAlign = 'justify';\n    elTeks.innerHTML = teks;\n    elKonten.appendChild(elTeks);\n}\n\n\n\nfunction fBuatHalaman(lebarHalaman, tinggiHalaman, xHalaman, yHalaman) {\n    const elHalaman = document.createElement('div');\n    elHalaman.style.width = lebarHalaman + 'px';\n    elHalaman.style.height = tinggiHalaman + 'px';\n    elHalaman.style.position = 'absolute';\n    elHalaman.style.left = xHalaman + 'px';\n    elHalaman.style.top = yHalaman + 'px';\n\n    const elKonten = fBuatSkroller(elHalaman, lebarHalaman, tinggiHalaman);\n    el.appendChild(elHalaman);\n\n    fBuatKonten(elKonten, lebarHalaman, tinggiHalaman)\n}\n\n\n\nfunction fAturTema(lebarLayar, tinggiLayar) {\n    el.style.width = lebarLayar + 'px';\n    el.style.height = tinggiLayar + 'px';\n    el.style.zIndex = 9999;\n    el.style.display = 'none';\n    el.style.position = 'fixed';\n    el.style.left = '0';\n    el.style.top = '0';\n\n    fAturTrei(lebarLayar, tinggiLayar);\n    fAturTombolLogin(lebarLayar, tinggiLayar);\n\n    const lebarHalaman = Math.floor(lebarLayar * 0.895);\n    const tinggiHalaman = Math.floor(tinggiLayar * 0.825);\n    const xHalaman = Math.floor(lebarLayar * 0.055);\n    const yHalaman = Math.floor(tinggiLayar * 0.030);\n\n    fBuatHalaman(lebarHalaman, tinggiHalaman, xHalaman, yHalaman);\n}\n\n\n\nfAturTema(window.innerWidth, window.innerHeight);\n\n\n\nfunction fTampilkan() {\n    window.__jangan_mundur = true;\n    __nonaktifkan_halaman();\n    el.style.display = 'block';\n}\n\n\n\nfunction fSembunyikan() {\n    window.__jangan_mundur = false;\n    el.style.display = 'none';\n    __aktifkan_halaman();\n}\n\n\n\n\n\n\nObject.defineProperty(window, '__harus_login__dalam__', {\n    value: {\n        tampilkanHal1: fTampilkan,\n        sembunyikanHal1: fSembunyikan,\n    },\n    writable: false,\n    configurable: false,\n    enumerable: false,\n});\n", "modul/z.login/3.input-nama.js": "\n\nconsole.log('membuat halaman harus_login-input-nama...');\n\n\n\n\nconst EL = document.createElement('div');\nEL.style.display = 'none';\nEL.style.position = 'absolute';\nEL.style.width = '100%';\nEL.style.height = '100%';\nEL.style.left = '0';\nEL.style.top = '0';\ndocument.body.appendChild(EL);\n\n\n\nconst elTombolTutup = document.createElement('div');\nEL.appendChild(elTombolTutup);\nconst mTombolTutupHalaman = __impor('modul/0tombol.tutup_halaman');\n\n\n\n\nfunction fAturTrei(lebarLayar, tinggiLayar) {\n    const gambarTreiAtas = __tema.gambar('trei-atas-2');\n    const gambarTreiTengah1 = __tema.gambar('trei-tengah-1');\n    const gambarTreiTengah2 = __tema.gambar('trei-tengah-2');\n    const gambarTreiBawah = __tema.gambar('trei-bawah-2');\n\n    const elTrei = document.createElement('div');\n    elTrei.style.position = 'absolute';\n    elTrei.style.top = '0';\n    elTrei.style.left = '0';\n    elTrei.style.width = '100%';\n    elTrei.style.height = '100%';\n    elTrei.style.margin = '0';\n    elTrei.style.padding = '0';\n\n    const elTreiAtas = document.createElement('img');\n    elTreiAtas.src = gambarTreiAtas;\n    elTreiAtas.style.display = 'block';\n    elTreiAtas.style.width = '100%';\n    elTreiAtas.style.height = '15%';\n    elTreiAtas.style.margin = '0';\n    elTrei.appendChild(elTreiAtas);\n\n    const elTreiTengah1 = document.createElement('img');\n    elTreiTengah1.src = gambarTreiTengah1;\n    elTreiTengah1.style.display = 'block';\n    elTreiTengah1.style.width = '100%';\n    elTreiTengah1.style.height = '35%';\n    elTreiTengah1.style.margin = '0';\n    elTrei.appendChild(elTreiTengah1);\n\n    const elTreiTengah2 = document.createElement('img');\n    elTreiTengah2.src = gambarTreiTengah2;\n    elTreiTengah2.style.display = 'block';\n    elTreiTengah2.style.width = '100%';\n    elTreiTengah2.style.height = '35%';\n    elTreiTengah2.style.margin = '0';\n    elTrei.appendChild(elTreiTengah2);\n\n    const elTreiBawah = document.createElement('img');\n    elTreiBawah.src = gambarTreiBawah;\n    elTreiBawah.style.display = 'block';\n    elTreiBawah.style.width = '100%';\n    elTreiBawah.style.height = '15%';\n    elTreiBawah.style.margin = '0';\n    elTrei.appendChild(elTreiBawah);\n\n    EL.prepend(elTrei);\n}\n\n\nfunction fAturTema(lebarLayar, tinggiLayar) {\n    fAturTrei(lebarLayar, tinggiLayar);\n}\n\n\n\nfunction fHitungTataLetakTombolTutupHalaman(ukuran) {\n    return {\n        dimensi: {\n            lebar: ukuran.ukuranTombolTutupHalaman,\n            tinggi: ukuran.ukuranTombolTutupHalaman\n        },\n        posisi: {\n            x: ukuran.lebarLayar * 0.88,\n            y: ukuran.tinggiLayar * 0.02\n        }\n    };\n}\n\n\n\nfunction fBuatTeks(elHalaman, tl) {\n    const elTeks = document.createElement('div');\n    elTeks.style.position = 'absolute';\n    elTeks.style.width = tl.lebarTeks + 'px';\n    elTeks.style.height = 'auto';\n    elTeks.style.left = tl.xTeks + 'px';\n    elTeks.style.top = tl.yTeks + 'px';\n    elTeks.style.fontSize = tl.ukuranTeks + 'px';\n    elTeks.style.fontFamily = __tema.teks('varianHuruf');\n    elTeks.style.color = __tema.warna('primer');\n    elTeks.innerHTML = 'Masukkan nama pengguna:';\n    elHalaman.appendChild(elTeks);\n}\n\n\n\nlet fPapanKetik_pilihSemua;\nlet fPapanKetik_ketik;\nlet fPapanKetik_hapus;\nlet fInput_ambil;\n\n\n\n\nfunction fSaatSelesai() {\n    fSembunyikanHalInputNama();\n    __harus_login__tampilkanHalInputKataSandi(fTampilkanHalInputNama);\n}\n\n\n\nfunction fBuatInput(elHalaman, tl) {\n    const teks = __data.ambil('login.nama') || '';\n\n    const mInput = __impor('modul/input');\n    const input = mInput.buat(teks, tl);\n\n    input.el.style.position = 'absolute';\n    input.el.style.left = tl.xInput + 'px';\n    input.el.style.top = tl.yInput + 'px';\n    elHalaman.appendChild(input.el);\n\n    fPapanKetik_pilihSemua = input.fPilihSemua;\n    fPapanKetik_ketik = input.fKetik;\n    fPapanKetik_hapus = input.fHapus;\n    fInput_ambil = input.fAmbil;\n}\n\n\n\nfunction fBuatPapanKetik(elHalaman, tl) {\n    let ctrl = false;\n\n    function fSimpan() {\n        const teks = fInput_ambil();\n        __data.simpan('login.nama', teks);\n    }\n\n    function fKetik(input) {\n        if (input == '[selesai]') {\n            fSaatSelesai();\n            return;\n        }\n        if (input == '[ctrl]') {\n            ctrl = true;\n            return;\n        }\n        if (input.length == 1) {\n            if (ctrl) {\n                if (input == 'a') {\n                    fPapanKetik_pilihSemua();\n                } else if (input == 'v') {\n                    const teks = __android.ambilPapanKlip();\n                    fPapanKetik_ketik(teks);\n                    fSimpan();\n                }\n                ctrl = false;\n            } else {\n                fPapanKetik_ketik(input);\n            }\n        } else if (input == '[hapus]') {\n            fPapanKetik_hapus();\n        }\n        fSimpan();\n    }\n\n    const mPapanKetik = __impor('modul/papan_ketik-login-nama');\n    const obj = mPapanKetik.buat(fKetik, {\n        lebarPapanKetik: tl.lebarPapanKetik,\n    });\n\n    obj.elPapanKetik.style.position = 'absolute';\n    obj.elPapanKetik.style.left = tl.xPapanKetik + 'px';\n    obj.elPapanKetik.style.bottom = tl.yPapanKetik + 'px';\n\n    elHalaman.appendChild(obj.elPapanKetik);\n}\n\n\nlet elTeksGagalLogin;\n\n\nfunction fBuatTeksGagalLogin(elHalaman, tl) {\n    elTeksGagalLogin = document.createElement('div');\n    elTeksGagalLogin.style.position = 'absolute';\n    elTeksGagalLogin.style.width = tl.lebarTeksGagalLogin + 'px';\n    elTeksGagalLogin.style.height = 'auto';\n    elTeksGagalLogin.style.transform = 'translate(-50%, -50%)';\n    elTeksGagalLogin.style.left = tl.xTeksGagalLogin + 'px';\n    elTeksGagalLogin.style.top = tl.yTeksGagalLogin + 'px';\n    elTeksGagalLogin.style.fontSize = __tema.teks('ukuranHuruf') + 'px';\n    elTeksGagalLogin.style.fontFamily = __tema.teks('varianHuruf');\n    elTeksGagalLogin.style.color = __tema.warna('error');\n    elTeksGagalLogin.style.textAlign = 'center';\n    elHalaman.appendChild(elTeksGagalLogin);\n\n    elTeksGagalLogin.innerHTML = '[GAGAL LOGIN]<br/> Nama pengguna / kata sandi salah';\n}\n\n\n\nfunction fBuatHalaman(tl) {\n    const elHalaman = document.createElement('div');\n    elHalaman.style.position = 'absolute';\n    elHalaman.style.width = tl.lebarHalaman + 'px';\n    elHalaman.style.height = tl.tinggiHalaman + 'px';\n    elHalaman.style.left = tl.xHalaman + 'px';\n    elHalaman.style.top = tl.yHalaman + 'px';\n    EL.appendChild(elHalaman);\n\n    fBuatTeks(elHalaman, tl);\n    fBuatInput(elHalaman, tl);\n    fBuatPapanKetik(elHalaman, tl);\n    fBuatTeksGagalLogin(elHalaman, tl);\n}\n\n\n\nfunction fHitungUkuran(lebarLayar, tinggiLayar) {\n    let marginX,\n        marginY,\n        spasiX,\n        spasiY,\n\n        lebarHalaman,\n        tinggiHalaman,\n        xHalaman,\n        yHalaman,\n\n        ukuranTombolTutupHalaman,\n\n        ukuranTeks,\n        lebarTeks,\n        xTeks,\n        yTeks,\n\n        lebarPapanKetik,\n        xPapanKetik,\n        yPapanKetik,\n\n        lebarInput,\n        tinggiInput,\n        xInput,\n        yInput,\n        paddingInput,\n\n        lebarTeksGagalLogin,\n        xTeksGagalLogin,\n        yTeksGagalLogin;\n\n    if (lebarLayar > tinggiLayar) {\n        // TODO\n        throw new Error('belum dimplementasikan');\n    } else {\n        marginX = 5;\n        marginY = 20;\n        spasiX = 5;\n        spasiY = 10;\n\n        ukuranTombolTutupHalaman = Math.min(30, Math.round(Math.min(lebarLayar, tinggiLayar) * 0.15));\n\n        lebarHalaman = Math.floor(lebarLayar * 0.895);\n        tinggiHalaman = Math.floor(tinggiLayar * 0.895);\n        xHalaman = Math.floor(lebarLayar * 0.055);\n        yHalaman = Math.floor(tinggiLayar * 0.080);\n\n        ukuranTeks = __tema.teks('ukuranHuruf');\n        lebarTeks = Math.floor(lebarHalaman * 0.94);\n        xTeks = Math.floor(lebarHalaman * 0.03);\n        yTeks = xTeks;\n\n        lebarPapanKetik = Math.floor(lebarHalaman * 1);;\n        xPapanKetik = Math.floor(lebarHalaman * 0);\n        yPapanKetik = Math.floor(tinggiHalaman * 0); // bottom\n\n        lebarInput = Math.floor(lebarHalaman * 1);\n        tinggiInput = __tema.teks('ukuranHuruf');\n        tinggiInput += Math.floor(tinggiInput * 0.5);\n        xInput = 0;\n        yInput = xTeks + ukuranTeks + Math.floor(ukuranTeks / 2);\n        paddingInput = Math.floor(lebarHalaman * 0.03);\n\n        const tinggiPapanKetik = Math.floor(lebarHalaman / 10) * 1.25 * 5;\n        const topPapanKetik = tinggiHalaman - tinggiPapanKetik;\n        const bottomInput = yInput + tinggiInput;\n        const tengahTeksGagalLogin = Math.floor((topPapanKetik - bottomInput) / 2);\n\n        lebarTeksGagalLogin = Math.floor(lebarHalaman * 0.90);\n        xTeksGagalLogin = Math.floor(lebarHalaman * 0.51); // center\n        yTeksGagalLogin = bottomInput + tengahTeksGagalLogin; // center\n    }\n\n    return {\n        lebarLayar,\n        tinggiLayar,\n\n        marginX,\n        marginY,\n        spasiX,\n        spasiY,\n\n        lebarHalaman,\n        tinggiHalaman,\n        xHalaman,\n        yHalaman,\n\n        ukuranTombolTutupHalaman,\n\n        ukuranTeks,\n        lebarTeks,\n        xTeks,\n        yTeks,\n\n        lebarPapanKetik,\n        xPapanKetik,\n        yPapanKetik,\n\n        lebarInput,\n        tinggiInput,\n        xInput,\n        yInput,\n        paddingInput,\n\n        lebarTeksGagalLogin,\n        xTeksGagalLogin,\n        yTeksGagalLogin,\n    };\n}\n\n\n\n\nfunction fBuatHalInputNama(lebarLayar, tinggiLayar) {\n    fAturTema(lebarLayar, tinggiLayar);\n\n    const tl = fHitungUkuran(lebarLayar, tinggiLayar);\n\n    const tlTombolTutupHalaman = fHitungTataLetakTombolTutupHalaman(tl);\n\n    const tombolTutupHalaman = mTombolTutupHalaman.buat(fSaatTombo