(lebarLayar * 0.895);\n        tinggiHalaman = Math.floor(tinggiLayar * 0.895);\n        xHalaman = Math.floor(lebarLayar * 0.055);\n        yHalaman = Math.floor(tinggiLayar * 0.080);\n\n        lebarLogo = Math.floor(lebarHalaman * 0.956);\n        tinggiLogo = Math.floor(tinggiHalaman * 0.4780);\n        xLogo = Math.floor(lebarHalaman * 0.022);\n        yLogo = Math.floor(tinggiHalaman * 0.012);\n\n        lebarBoks = Math.floor(lebarHalaman * 0.950);\n        tinggiBoks = Math.floor(tinggiHalaman * 0.408);\n        xBoks = xLogo;\n        yBoks = yLogo + tinggiLogo + Math.floor(tinggiHalaman * 0.016);\n\n        ukuranTeks = Math.floor(tinggiHalaman * 0.06);\n\n        lebarTombolBeli = Math.floor(lebarHalaman * 0.72);\n        tinggiTombolBeli = Math.floor(tinggiHalaman * 0.08);\n        xTombolBeli = Math.floor(lebarLayar * 0.50);\n        yTombolBeli = Math.floor(tinggiLayar * 0.915);\n    }\n\n    return {\n        lebarLayar,\n        tinggiLayar,\n\n        marginX,\n        marginY,\n        spasiX,\n        spasiY,\n\n        lebarHalaman,\n        tinggiHalaman,\n        xHalaman,\n        yHalaman,\n\n        ukuranTombolTutupHalaman,\n\n        lebarLogo,\n        tinggiLogo,\n        xLogo,\n        yLogo,\n\n        lebarBoks,\n        tinggiBoks,\n        xBoks,\n        yBoks,\n\n        ukuranTeks,\n\n        lebarTombolBeli,\n        tinggiTombolBeli,\n        xTombolBeli,\n        yTombolBeli,\n    };\n}\n\n\n\nfunction fAturTataLetakPotret(lebarLayar, tinggiLayar) {\n    mLog.jejak('mengatur tata letak potret halaman produk');\n\n    fInisiasi(lebarLayar, tinggiLayar);\n    fAturTema(lebarLayar, tinggiLayar);\n\n    const tl = fHitungUkuran(lebarLayar, tinggiLayar);\n\n    const tlTombolTutupHalaman = fHitungTataLetakTombolTutupHalaman(tl);\n\n    tombolTutupHalaman.aturDimensi(tlTombolTutupHalaman.dimensi.lebar, tlTombolTutupHalaman.dimensi.tinggi);\n    tombolTutupHalaman.aturPosisi(tlTombolTutupHalaman.posisi.x, tlTombolTutupHalaman.posisi