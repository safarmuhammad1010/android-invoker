'' + halTotal;\n    }\n    perbaruiKonterSekarang(vHalSekarang);\n    perbaruiKonterTotal(vHalTotal);\n\n    __data.pantau('hal_histori-hal_sekarang', (_, halSekarang) => {\n        perbaruiKonterSekarang(parseInt(halSekarang));\n    });\n    __data.pantau('hal_histori-hal_total', (_, halTotal) => {\n        perbaruiKonterTotal(parseInt(halTotal));\n    });\n}\n\n\nfunction fAturTombol(lebarLayar, tinggiLayar, lebarTombol, tinggiTombol, spasi) {\n    const gambarTombolMundur1 = __impor('aset/gambar/tombol-mundur-1.png');\n    const gambarTombolMundur2 = __impor('aset/gambar/tombol-mundur-2.png');\n    const gambarTombolMaju1 = __impor('aset/gambar/tombol-maju-1.png');\n    const gambarTombolMaju2 = __impor('aset/gambar/tombol-maju-2.png');\n\n    const srcTombolMundurNormal = `data:image/png;base64,${gambarTombolMundur1}`;\n    const srcTombolMundurDitekan = `data:image/png;base64,${gambarTombolMundur2}`;\n    const srcTombolMundurNonaktif = `data:image/png;base64,${gambarTombolMundur2}`;\n\n    const srcTombolMajuNormal = `data:image/png;base64,${gambarTombolMaju1}`;\n    const srcTombolMajuDitekan = `data:image/png;base64,${gambarTombolMaju2}`;\n    const srcTombolMajuNonaktif = `data:image/png;base64,${gambarTombolMaju2}`;\n\n    const xMundur = Math.floor(lebarLayar * 0.05) + (lebarTombol * 2 + spasi) + spasi;\n\n    const elTombolMundur = document.createElement('img');\n    elTombolMundur.src = (vHalSekarang > 1) ? srcTombolMundurNormal : srcTombolMundurNonaktif;\n    elTombolMundur.style.position = 'absolute';\n    elTombolMundur.style.width = lebarTombol + 'px';\n    elTombolMundur.style.height = tinggiTombol + 'px';\n    elTombolMundur.style.bottom = Math.floor(tinggiLayar * 0.020) + 'px';\n    elTombolMundur.style.left = xMundur + 'px';\n    __el.appendChild(elTombolMundur);\n\n    const elTombolMaju = document.createElement('img');\n    elTombolMaju.src = (vHalSekarang < vHalTotal) ? srcTombolMajuNormal : srcTombolMajuNonaktif;\n    elTombolMaju.style.position = 'absolute';\n    elTombolMaju.style.width = lebarTombol + 'px';\n    elTombolMaju.style.height = tinggiTombol + 'px';\n    elTombolMaju.style.bottom = Math.floor(tinggiLayar * 0.020) + 'px';\n    elTombolMaju.style.left = (xMundur + lebarTombol + spasi) + 'px';\n    __el.appendChild(elTombolMaju);\n\n    let tombolMundurDitekan = false;\n    let tombolMajuDitekan = false;\n    elTombolMundur.addEventListener('click', () => {\n        if (tombolMundurDitekan) return;\n        if (vHalSekarang <= 1) return;\n        tombolMundurDitekan = true;\n        elTombolMundur.src = srcTombolMundurDitekan;\n        setTimeout(() => {\n            tombolMundurDitekan = false;\n            saatTombolMundurDitekan();\n        }, 100);\n    });\n    elTombolMaju.addEventListener('click', () => {\n        if (tombolMajuDitekan) return;\n        if (vHalSekarang >= vHalTotal) return;\n        tombolMajuDitekan = true;\n        elTombolMaju.src = srcTombolMajuDitekan;\n        setTimeout(() => {\n            tombolMajuDitekan = false;\n            saatTombolMajuDitekan();\n        }, 100);\n    });\n\n    __data.pantau('hal_histori-hal_sekarang', (_, halSekarang) => {\n        if (halSekarang >= vHalTotal) {\n            elTombolMaju.src = srcTombolMajuNonaktif;\n        } else {\n            elTombolMaju.src = srcTombolMajuNormal;\n        }\n        if (halSekarang > 1) {\n            elTombolMundur.src = srcTombolMundurNormal;\n        } else {\n            elTombolMundur.src = srcTombolMundurNonaktif;\n        }\n    });\n}\n\n\nfunction fAturTema(lebarLayar, tinggiLayar) {\n    const lebarTombol = Math.floor((lebarLayar * 0.86) / 4);\n    const tinggiTombol = Math.floor(tinggiLayar * 0.06);\n    const spasi = Math.floor(((lebarLayar * 0.91) - (lebarTombol * 4)) / 3);\n\n    __el.style.position = 'relative';\n    fAturTrei(lebarLayar, tinggiLayar);\n    fAturKonter(lebarLayar, tinggiLayar, lebarTombol, tinggiTombol, spasi);\n    fAturTombol(lebarLayar, tinggiLayar, lebarTombol, tinggiTombol, spasi);\n}\n\n\n\nfunction fInisiasi(lebarLayar, tinggiLayar) {\n    tombolTutupHalaman.inisiasi(__el.querySelector('#tutup_halaman'), lebarLayar, tinggiLayar);\n}\n\n\n\nfunction fHitungTataLetakTombolTutupHalaman(ukuran) {\n    return {\n        dimensi: {\n            lebar: ukuran.ukuranTombolTutupHalaman,\n            tinggi: ukuran.ukuranTombolTutupHalaman\n        },\n        posisi: {\n            x: ukuran.lebarLayar * 0.88,\n            y: ukuran.tinggiLayar * 0.02\n        }\n    };\n}\n\n\n\nfunction fHitungUkuran(lebarLayar, tinggiLayar) {\n    let marginX,\n        marginY,\n        spasiX,\n        spasiY,\n        ukuranTombolTutupHalaman;\n\n    if (lebarLayar > tinggiLayar) {\n        // TODO\n        throw new Error('belum dimplementasikan');\n    } else {\n        marginX = 5;\n        marginY = 20;\n        spasiX = 5;\n        spasiY = 10;\n\n        ukuranTombolTutupHalaman = Math.min(30, Math.round(Math.min(lebarLayar, tinggiLayar) * 0.15));\n    }\n\n    return {\n        lebarLayar,\n        tinggiLayar,\n        marginX,\n        marginY,\n        spasiX,\n        spasiY,\n        ukuranTombolTutupHalaman\n    };\n}\n\n\n\nfunction fBuatHalaman(lebarLayar, tinggiLayar) {\n    lebarHalaman = Math.floor(lebarLayar * 0.895);\n    tinggiHalaman = Math.floor(tinggiLayar * 0.825);\n    const xHalaman = Math.floor(lebarLayar * 0.055);\n    const yHalaman = Math.floor(tinggiLayar * 0.080);\n\n    elHalaman = document.createElement('div');\n    elHalaman.style.position = 'absolute';\n    elHalaman.style.width = lebarHalaman + 'px';\n    elHalaman.style.height = tinggiHalaman + 'px';\n    elHalaman.style.left = xHalaman + 'px';\n    elHalaman.style.top = yHalaman + 'px';\n    __el.appendChild(elHalaman);\n\n    const elKosong = document.createElement('div');\n    elKosong.style.position = 'absolute';\n    elKosong.style.left = '50%';\n    elKosong.style.top = '50%';\n    elKosong.style.transform = 'translate(-50%,-50%)';\n    elKosong.style.fontFamily = __tema.teks('varianHuruf');\n    elKosong.style.fontSize = __tema.teks('ukuranHuruf') + 'px';\n    elKosong.style.color = __tema.warna('primer');\n    elKosong.innerHTML = 'kosong';\n    elHalaman.appendChild(elKosong);\n\n    fKeHalaman(vHalSekarang);\n}\n\n\n\n\nfunction fAturTataLetakPotret(lebarLayar, tinggiLayar) {\n    mLog.jejak('mengatur tata letak potret halaman histori');\n\n    fInisiasi(lebarLayar, tinggiLayar);\n    fAturTema(lebarLayar, tinggiLayar);\n\n    const ukuran = fHitungUkuran(lebarLayar, tinggiLayar);\n\n    const tlTombolTutupHalaman = fHitungTataLetakTombolTutupHalaman(ukuran);\n\n    tombolTutupHalaman.aturDimensi(tlTombolTutupHalaman.dimensi.lebar, tlTombolTutupHalaman.dimensi.tinggi);\n    tombolTutupHalaman.aturPosisi(tlTombolTutupHalaman.posisi.x, tlTombolTutupHalaman.posisi.y);\n\n    fBuatHalaman(lebarLayar, tinggiLayar);\n}\n\n\n\n\nfunction fAturTataLetakLanskap(lebarLayar, tinggiLayar) {\n    mLog.jejak('mengatur tata letak lanskap halaman histori');\n    // TODO\n    throw new Error('belum dimplementasikan');\n}\n\n\n\n\nfunction fBuka() {\n    fKeHalaman(vHalSekarang);\n}\n\n\n\n__ekspor('buka', fBuka);\n\n\n\n\n__ekspor('aturTataLetak', (lebarLayar, tinggiLayar) => {\n    if (lebarLayar >= tinggiLayar) {\n        fAturTataLetakLanskap(lebarLayar, tinggiLayar);\n    } else {\n        fAturTataLetakPotret(lebarLayar, tinggiLayar);\n    }\n});\n"}, "lempar_dadu": {"halaman/lempar_dadu/indeks.css": "{{el}} {\n\n}\n", "halaman/lempar_dadu/indeks.html": "\n<div id=\"tutup_halaman\"></div>\n", "halaman/lempar_dadu/indeks.js": "const log = __impor('modul/0log');\n\n\nlog.info('memuat halaman lempar_dadu');\n", "halaman/lempar_dadu/tata_letak.js": "const mLog = __impor('modul/0log');\nconst mInsentif = __impor('modul/1insentif');\n\nconst mTombolTutupHalaman = __impor('modul/0tombol.tutup_halaman');\n\n\nconst mHalamanIntro = __impor('modul/lempar_dadu.intro');\nconst mHalamanOutro = __impor('modul/lempar_dadu.outro');\nconst mHalamanGem = __impor('modul/gem.tebak_kartu');\n\n\n\nconst tombolTutupHalaman = mTombolTutupHalaman.buat();\n\n\n\nfunction fAturTrei(lebarLayar, tinggiLayar) {\n    const gambarTreiAtas = __impor('aset/gambar/trei-atas-1.png');\n    const gambarTreiTengah1 = __impor('aset/gambar/trei-tengah-1.png');\n    const gambarTreiTengah2 = __impor('aset/gambar/trei-tengah-2.png');\n    const gambarTreiBawah = __impor('aset/gambar/trei-bawah-1.png');\n\n    const elTrei = document.createElement('div');\n    elTrei.style.position = 'absolute';\n    elTrei.style.top = '0';\n    elTrei.style.left = '0';\n    elTrei.style.width = '100%';\n    elTrei.style.height = '100%';\n    elTrei.style.margin = '0';\n    elTrei.style.padding = '0';\n\n    const elTreiAtas = document.createElement('img');\n    elTreiAtas.src = `data:image/png;base64,${gambarTreiAtas}`;\n    elTreiAtas.style.display = 'block';\n    elTreiAtas.style.width = '100%';\n    elTreiAtas.style.height = '15%';\n    elTreiAtas.style.margin = '0';\n    elTrei.appendChild(elTreiAtas);\n\n    const elTreiTengah1 = document.createElement('img');\n    elTreiTengah1.src = `data:image/png;base64,${gambarTreiTengah1}`;\n    elTreiTengah1.style.display = 'block';\n    elTreiTengah1.style.width = '100%';\n    elTreiTengah1.style.height = '35%';\n    elTreiTengah1.style.margin = '0';\n    elTrei.appendChild(elTreiTengah1);\n\n    const elTreiTengah2 = document.createElement('img');\n    elTreiTengah2.src = `data:image/png;base64,${gambarTreiTengah2}`;\n    elTreiTengah2.style.display = 'block';\n    elTreiTengah2.style.width = '100%';\n    elTreiTengah2.style.height = '35%';\n    elTreiTengah2.style.margin = '0';\n    elTrei.appendChild(elTreiTengah2);\n\n    const elTreiBawah = document.createElement('img');\n    elTreiBawah.src = `data:image/png;base64,${gambarTreiBawah}`;\n    elTreiBawah.style.display = 'block';\n    elTreiBawah.style.width = '100%';\n    elTreiBawah.style.height = '15%';\n    elTreiBawah.style.