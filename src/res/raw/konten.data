    elTombolMundur.addEventListener('click', () => {\n        if (tombolMundurDitekan) return;\n        if (vHalSekarang <= 1) return;\n        tombolMundurDitekan = true;\n        elTombolMundur.src = srcTombolMundurDitekan;\n        setTimeout(() => {\n            tombolMundurDitekan = false;\n            saatTombolMundurDitekan();\n        }, 100);\n    });\n    elTombolMaju.addEventListener('click', () => {\n        if (tombolMajuDitekan) return;\n        if (vHalSekarang >= vHalTotal) return;\n        tombolMajuDitekan = true;\n        elTombolMaju.src = srcTombolMajuDitekan;\n        setTimeout(() => {\n            tombolMajuDitekan = false;\n            saatTombolMajuDitekan();\n        }, 100);\n    });\n\n    __data.pantau('hal_misi-hal_sekarang', (_, halSekarang) => {\n        if (halSekarang >= vHalTotal) {\n            elTombolMaju.src = srcTombolMajuNonaktif;\n        } else {\n            elTombolMaju.src = srcTombolMajuNormal;\n        }\n        if (halSekarang > 1) {\n            elTombolMundur.src = srcTombolMundurNormal;\n        } else {\n            elTombolMundur.src = srcTombolMundurNonaktif;\n        }\n    });\n}\n\n\nfunction fAturTema(lebarLayar, tinggiLayar) {\n    const lebarTombol = Math.floor((lebarLayar * 0.86) / 4);\n    const tinggiTombol = Math.floor(tinggiLayar * 0.06);\n    const spasi = Math.floor(((lebarLayar * 0.91) - (lebarTombol * 4)) / 3);\n\n    __el.style.position = 'relative';\n    fAturTrei(lebarLayar, tinggiLayar);\n    fAturKonter(lebarLayar, tinggiLayar, lebarTombol, tinggiTombol, spasi);\n    fAturTombol(lebarLayar, tinggiLayar, lebarTombol, tinggiTombol, spasi);\n}\n\n\n\n\nfunction fInisiasi(lebarLayar, tinggiLayar) {\n    tombolTutupHalaman.inisiasi(__el.querySelector('#tutup_halaman'), lebarLayar, tinggiLayar);\n}\n\n\n\nfunction fHitungTataLetakTombolTutupHalaman(ukuran) {\n    return {\n        dimensi: {\n            lebar: ukuran.ukuranTombolTutupHalaman,\n            tinggi: ukuran.ukuranTombolTutupHalaman\