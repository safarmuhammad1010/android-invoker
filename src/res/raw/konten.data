) {\n    const gambarTreiAtas = __tema.gambar('trei-atas-3');\n    const gambarTreiTengah1 = __tema.gambar('trei-tengah-1');\n    const gambarTreiTengah2 = __tema.gambar('trei-tengah-2');\n    const gambarTreiBawah = __tema.gambar('trei-bawah-3');\n\n    const elTrei = document.createElement('div');\n    elTrei.style.position = 'absolute';\n    elTrei.style.top = '0';\n    elTrei.style.left = '0';\n    elTrei.style.width = '100%';\n    elTrei.style.height = '100%';\n    elTrei.style.margin = '0';\n    elTrei.style.padding = '0';\n\n    const elTreiAtas = document.createElement('img');\n    elTreiAtas.src = gambarTreiAtas;\n    elTreiAtas.style.display = 'block';\n    elTreiAtas.style.width = '100%';\n    elTreiAtas.style.height = '15%';\n    elTreiAtas.style.margin = '0';\n    elTrei.appendChild(elTreiAtas);\n\n    const elTreiTengah1 = document.createElement('img');\n    elTreiTengah1.src = gambarTreiTengah1;\n    elTreiTengah1.style.display = 'block';\n    elTreiTengah1.style.width = '100%';\n    elTreiTengah1.style.height = '35%';\n    elTreiTengah1.style.margin = '0';\n    elTrei.appendChild(elTreiTengah1);\n\n    const elTreiTengah2 = document.createElement('img');\n    elTreiTengah2.src = gambarTreiTengah2;\n    elTreiTengah2.style.display = 'block';\n    elTreiTengah2.style.width = '100%';\n    elTreiTengah2.style.height = '35%';\n    elTreiTengah2.style.margin = '0';\n    elTrei.appendChild(elTreiTengah2);\n\n    const elTreiBawah = document.createElement('img');\n    elTreiBawah.src = gambarTreiBawah;\n    elTreiBawah.style.display = 'block';\n    elTreiBawah.style.width = '100%';\n    elTreiBawah.style.height = '15%';\n    elTreiBawah.style.margin = '0';\n    elTrei.appendChild(elTreiBawah);\n\n    el.prepend(elTrei);\n}\n\n\n\nfunction fAturTombolOK(lebarLayar, tinggiLayar) {\n    const gambarNormal = __tema.gambar('tombol-ok-1');\n    const gambarDitekan = __tema.gambar('tombol-ok-2');\n\n    const elTombolOK = document.createElement('img');\n    elTombolOK.style.position = 'absolute';\n    elTombolOK.style.width = '40%';\n    elTombolOK.style.height = '6%';\n    elTombolOK.style.right = '5%';\n    elTombolOK.style.top = '92%';\n    elTombolOK.src = gambarNormal;\n    el.appendChild(elTombolOK);\n\n    elTombolOK.addEventListener('click', () => {\n        elTombolOK.src = gambarDitekan;\n        setTimeout(() => {\n            elTombolOK.src = gambarNormal;\n            fSembunyikan();\n            const i = __saat_mundur.indexOf(fSembunyikan);\n            __saat_mundur.splice(i, 1);\n        }, 200);\n    });\n}\n\n\n\n\nfunction fBuatSkroller(elKontener, lebarKontener, tinggiKontener) {\n    const oSkroller = mSkroller.buat(lebarKontener, tinggiKontener);\n    elKontener.appendChild(oSkroller.kontener());\n    return oSkroller.konten();\n}\n\n\n\nfunction fBuatHalaman(lebarHalaman, tinggiHalaman, xHalaman, yHalaman) {\n    const elHalaman = document.createElement('div');\n    elHalaman.style.width = lebarHalaman + 'px';\n    elHalaman.style.height = tinggiHalaman + 'px';\n    elHalaman.style.position = 'absolute';\n    elHalaman.style.left = xHalaman + 'px';\n    elHalaman.style.top = yHalaman + 'px';\n    el.appendChild(elHalaman);\n\n    const elKonten = fBuatSkroller(elHalaman, lebarHalaman, tinggiHalaman);\n    elKonten.style.width = '90%';\n    elKonten.style.height = 'auto';\n    elKonten.style.position = 'absolute';\n    elKonten.style.transform = 'translate(-50%, -50%)';\n    elKonten.style.left = '50%';\n    elKonten.style.top = '50%';\n    elKonten.style.textAlign = 'center';\n    elKonten.style.color = __tema.warna('primer');\n    elKonten.style.fontSize = __tema.teks('ukuranHuruf');\n    elKonten.style.fontFamily = __tema.teks('varianHuruf');\n    elKonten.innerHTML = 'kredit tidak cukup';\n}\n\n\n\nfunction fAturTema(lebarLayar, tinggiLayar) {\n    el.style.width = lebarLayar + 'px';\n    el.style.height = tinggiLayar + 'px';\n    el.style.zIndex = 9999;\n    el.style.display = 'none';\n    el.style.position = 'fixed';\n    el.style.left = '0';\n    el.style.top = '0';\n\n    fAturTrei(lebarLayar, tinggiLayar);\n    fAturTombolOK(lebarLayar, tinggiLayar);\n\n    const lebarHalaman = Math.floor(lebarLayar * 0.895);\n    const tinggiHalaman = Math.floor(tinggiLayar * 0.825);\n    const xHalaman = Math.floor(lebarLayar * 0.055);\n    const yHalaman = Math.floor(tinggiLayar * 0.030);\n\n    fBuatHalaman(lebarHalaman, tinggiHalaman, xHalaman, yHalaman);\n}\n\n\n\nfAturTema(window.innerWidth, window.innerHeight);\n\n\n\n\n\nfunction fTampilkan() {\n    __nonaktifkan_halaman();\n    el.style.display = 'block';\n    __saat_mundur.push(fSembunyikan);\n}\n\n\nfunction fSembunyikan() {\n    el.style.display = 'none';\n    __aktifkan_halaman();\n}\n\n\n\n__ekspor('tampilkan', fTampilkan);\n"}, "etalase.market": {"modul/etalase.market/indeks.js": "\nconst gambarLatar1 = __impor('aset/gambar/tmb-market-1.png');\nconst gambarLatar2 = __impor('aset/gambar/tmb-market-2.png');\n\n\nlet elLatar;\nlet elJumlahMarket;\n\n\nfunction fAturUkuranDanPosisiTeks(lebarKontener, tinggiKontener) {\n    if (!elJumlahMarket) return;\n\n    const ukuranTeks = Math.floor(tinggiKontener * 0.1);\n    const yTeks = ukuranTeks;\n    const xTeks = Math.floor((lebarKontener / 2));\n\n    elJumlahMarket.style.position = 'absolute';\n    elJumlahMarket.style.fontSize = elJumlahMarket.style.lineHeight = ukuranTeks + 'px';\n    elJumlahMarket.style.transform = 'translate(50%, 0)';\n    elJumlahMarket.style.top = yTeks + 'px';\n    elJumlahMarket.style.right = xTeks + 'px';\n    elJumlahMarket.style.padding = 0;\n    elJumlahMarket.style.margin = 0;\n    elJumlahMarket.style.userSelect = 'none';\n    elJumlahMarket.style.opacity = '0.7';\n}\n\n\nfunction fInisiasi(el, lebarLayar, tinggiLayar) {\n    console.debug('inisiasi etalase.market');\n    el.innerHTML = '';\n\n    elLatar = document.createElement('img');\n    elJumlahMarket = document.createElement('div');\n    el.appendChild(elLatar);\n    el.appendChild(elJumlahMarket);\n\n    __data.pantau('volume_market', (_, nilai) => {\n        elJumlahMarket.innerHTML = __format_konter_etalase(nilai);\n    });\n}\n\n\nfunction fAturTema(el, lebarLayar, tinggiLayar) {\n    const gambarNormal = `data:image/png;base64,${gambarLatar1}`;\n    const gambarDitekan = `data:image/png;base64,${gambarLatar2}`;\n    elLatar.src = gambarNormal;\n    __klik(el, () => {\n        elLatar.src = gambarDitekan;\n    }, () => {\n        elLatar.src = gambarNormal;\n        __ke('market');\n        __suara1();\n    }, 200);\n    elJumlahMarket.style.fontFamily = 'monospace';\n    elJumlahMarket.style.color = __tema.warna('nilai');\n}\n\n\nfunction fBuat() {\n    let el = null;\n    return {\n        inisiasi: (_el, lebarLayar, tinggiLayar) => {\n            if (!_el) {\n                throw new Error('parameter invalid: _el tiada');\n            }\n            el = _el;\n            el.style.position = 'fixed';\n            fInisiasi(_el, lebarLayar, tinggiLayar);\n            fAturTema(el, lebarLayar, tinggiLayar);\n        },\n        aturDimensi: (lebar, tinggi) => {\n            if (!el) {\n                throw new Error('algoritma invalid: __el tiada');\n            }\n            el.style.width = elLatar.style.width = lebar + 'px';\n            el.style.height = elLatar.style.height = tinggi + 'px';\n            fAturUkuranDanPosisiTeks(lebar, tinggi);\n        },\n        aturPosisi: (x, y) => {\n            if (!el) {\n                throw new Error('algoritma invalid: __el tiada');\n            }\n            el.style.left = x + 'px';\n            el.style.top = y + 'px';\n        }\n    };\n}\n\n\n__ekspor('buat', fBuat);\n"}, "profil.piagam": {"modul/profil.piagam/index.js": "\n\n\nfunction fBuatKonten(elKontener, lebarKontener, tinggiKontener) {\n    const ukuranTeks = Math.floor(lebarKontener * 0.05);\n    const xTengah = Math.floor(lebarKontener * 0.5);\n    const yTengah = Math.floor(tinggiKontener * 0.5);\n\n    const e