object for the start of the next day (midnight)\n  const nextDay = new Date(now);\n  nextDay.setDate(now.getDate() + 1); // Increment the day\n  nextDay.setHours(0, 0, 0, 0); // Set time to midnight (00:00:00.000)\n\n  // 3. Calculate the difference in milliseconds\n  const diffInMilliseconds = nextDay.getTime() - now.getTime(); //\n\n  // 4. Convert the milliseconds difference to hours\n  // There are 1000 ms per second, 60 seconds per minute, 60 minutes per hour.\n  const hours = diffInMilliseconds / (1000 * 60 * 60);\n\n  // Return the number of hours (can be a floating-point number)\n  return Math.floor(hours);\n}\n\n\n\nfunction getDaysUntilNextMonday() {\n    const today = new Date().getDay(); // 0 (Sun) to 6 (Sat)\n    // If today is Monday (1), days until next Monday is 7.\n    // Otherwise, it's 1 (Mon) - today + 7, modulo 7.\n    const daysToNextMonday = today === 1 ? 7 : (8 - today) % 7 || 7;\n    return daysToNextMonday;\n}\n\n\n\nfunction getDaysSince(startDateString) {\n  // A day in UTC always lasts 24 hours (unlike in other time formats)\n  const oneDayInMs = 1000 * 60 * 60 * 24;\n\n  // Convert the start date string to a Date object\n  const startDate = new Date(startDateString);\n  const currentDate = new Date();\n\n  // Get UTC timestamps for both dates, set to midnight\n  const startUTC = Date.UTC(startDate.getFullYear(), startDate.getMonth(), startDate.getDate());\n  const currentUTC = Date.UTC(currentDate.getFullYear(), currentDate.getMonth(), currentDate.getDate());\n\n  // Calculate the difference in milliseconds\n  const differenceMs = Math.abs(currentUTC - startUTC);\n\n  // Convert the difference back to days\n  return Math.floor(differenceMs / oneDayInMs);\n}\n\n\nfunction fHitungMingguDari(a, b) {\n  // A day in UTC always lasts 24 hours (unlike in other time formats)\n  const oneDayInMs = 1000 * 60 * 60 * 24;\n\n  // Convert the start date string to a Date object\n  const startDate = new Date(a);\n  const currentDate = new Date(b);\n\n  // Get UTC timestamps for both dates, set to midnight\n  const startUTC = Date.UTC(startDate.getFullYear(), startDate.getMonth(), startDate.getDate());\n  const currentUTC = Date.UTC(currentDate.getFullYear(), currentDate.getMonth(), currentDate.getDate());\n\n  // Calculate the difference in milliseconds\n  const differenceMs = Math.abs(currentUTC - startUTC);\n\n  // Convert the difference back to days\n  return Math.floor(differenceMs / oneDayInMs);\n}\n\n\n\nfunction fCekLotreMingguan() {\n    const tglIkut = __data.ambil('lotre_7H-ikut');\n    if (!tglIkut) return false;\n\n    const tglAwal = __data.ambil('lotre_7H-awal');\n    if (!tglAwal) throw Error('tglAwal == undefined');\n\n    const n1 = fHitungMingguDari(tglAwal, new Date());\n    const x1 = Math.floor(n1 / 7);\n\n    const n2 = fHitungMingguDari(tglAwal, tglIkut);\n    const x2 = Math.floor(n2 / 7);\n\n    return x1 === x2;\n}\n\n\n\nfunction fPutaranSaatIni() {\n    const tglAwal = __data.ambil('lotre_7H-awal');\n    if (!tglAwal) throw Error('tglAwal == undefined');\n    const n = getDaysSince(tglAwal);\n    const x = Math.floor(n / 7);\n    return `Minggu ${x}`;\n}\n\n\n\n\nfunction fAturTrei(lebarLayar, tinggiLayar) {\n    const gambarTreiAtas = __impor('aset/gambar/trei-atas-2.png');\n    const gambarTreiTengah1 = __impor('aset/gambar/trei-tengah-1.png');\n    const gambarTreiTengah2 = __impor('aset/gambar/trei-tengah-2.png');\n    const gambarTreiBawah = __impor('aset/gambar/trei-bawah-2.png');\n\n    const elTrei = document.createElement('div');\n    elTrei.style.position = 'absolute';\n    elTrei.style.top = '0';\n    elTrei.style.left = '0';\n    elTrei.style.width = '100%';\n    elTrei.style.height = '100%';\n    elTrei.style.margin = '0';\n    elTrei.style.padding = '0';\n\n    const elTreiAtas = document.createElement('img');\n    elTreiAtas.src = `data:image/png;base64,${gambarTreiAtas}`;\n    elTreiAtas.style.display = 'block';\n    elTreiAtas.style.width = '100%';\n    elTreiAtas.styl