'';\n    el.style.backgroundColor = '';\n    el.style.display = 'flex';\n    el.style.justifyContent = 'flex-end';\n    el.style.alignItems = 'center';\n\n    const tlTeksLevel = fHitungTlTeksLevel(lebar, tinggi);\n    const tlBarLevel = fHitungTlBarLevel(lebar, tinggi, tlTeksLevel);\n\n    fRenderBarLevel(el, lebar, tinggi, tlBarLevel, xp);\n    fRenderTeksLevel(el, lebar, tinggi, tlTeksLevel, xp);\n}\n\n\nfunction fBuat() {\n    let el = null;\n    return {\n        inisiasi: (_el, lebarLayar, tinggiLayar) => {\n            if (!_el) {\n                throw new Error('parameter invalid: _el tiada');\n            }\n            el = _el;\n            el.style.position = 'fixed';\n            fInisiasi(_el, lebarLayar, tinggiLayar);\n            fAturTema(el, lebarLayar, tinggiLayar);\n        },\n        aturDimensi: (lebar, tinggi) => {\n            if (!el) {\n                throw new Error('algoritma invalid: __el tiada');\n            }\n            el.style.width = lebar + 'px';\n            el.style.height = tinggi + 'px';\n\n            const xp = __data.ambil('xp');\n            if (typeof(xp) === 'undefined') {\n                fRender(el, lebar, tinggi, xp);\n            }\n            __data.pantau('xp', (_, xp) => {\n                fRender(el, lebar, tinggi, xp);\n            });\n        },\n        aturPosisi: (x, y) => {\n            if (!el) {\n                throw new Error('algoritma invalid: __el tiada');\n            }\n            el.style.left = x + 'px';\n            el.style.top = y + 'px';\n        }\n    };\n}\n\n\n__ekspor('buat', fBuat);\n"}, "papan_ketik-3": {"modul/papan_ketik-3/indeks.js": "\n\n\nfunction fBuat(f, opsi) {\n    const elPapanKetik = document.createElement('div');\n    elPapanKetik.style.width = opsi.lebarPapanKetik + 'px';\n\n    const lebarTombol1 = Math.floor(opsi.lebarPapanKetik / 3);\n    const tinggiTombol1 = Math.floor(lebarTombol1 * 0.80);\n    const tinggiPapanKetik = tinggiTombol1 * 4;\n    const ukuranTeks = Math.floor(lebarTombol1 * 0.7);\n\n    elPapanKetik.style.height = tinggiPapanKetik + 'px';\n\n    const lisBaris = [\n        ['1', '2', '3',],\n        ['4', '5', '6',],\n        ['7', '8', '9',],\n        ['[hapus]', '0', '[selesai]'],\n    ];\n\n    let elTombolSelesai;\n\n    let h = 0;\n    for (const baris of lisBaris) {\n        let i = 0;\n        for (const huruf of baris) {\n            let x = Math.floor(lebarTombol1 * i);\n            const y = tinggiTombol1 * h + 1;\n            i += 1;\n\n            if (h == 90) {\n                x += Math.floor(lebarTombol1 / 2);\n            }\n\n            const elTombol = document.createElement('div');\n            elTombol.style.position = 'absolute';\n            elTombol.style.width = (lebarTombol1-1) + 'px';\n            elTombol.style.height = (tinggiTombol1-1) + 'px';\n            elTombol.style.left = x + 'px';\n            elTombol.style.top = y + 'px';\n            elPapanKetik.appendChild(elTombol);\n\n            const elTrei = document.createElement('img');\n            elTrei.style.position = 'absolute';\n            elTrei.style.width = '100%';\n            elTrei.style.height = '100%';\n            elTrei.src = __tema.gambar('papan_ketik-latar-1');\n            elTombol.appendChild(elTrei);\n\n            if (huruf.length == 1) {\n                const elTeks = document.createElement('div');\n                elTeks.style.position = 'absolute';\n                elTeks.style.transform = 'translate(-50%,-50%)';\n                elTeks.style.left = '50%';\n                elTeks.style.top = '50%';\n                elTeks.style.fontSize = ukuranTeks + 'px';\n                elTeks.style.fontFamily = __tema.teks('varianHuruf');\n                elTeks.style.color = __tema.warna('primer');\n                elTeks.innerHTML = huruf;\n                elTombol.appendChild(elTeks);\n            }\n\n            if (huruf == '[hapus]') {\n                elTrei.src = __tema.gambar('papan_ketik-3-hapus-1')