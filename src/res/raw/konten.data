bolTutupHalaman = fHitungTataLetakTombolTutupHalaman(ukuran);\n\n    tombolTutupHalaman.aturDimensi(tlTombolTutupHalaman.dimensi.lebar, tlTombolTutupHalaman.dimensi.tinggi);\n    tombolTutupHalaman.aturPosisi(tlTombolTutupHalaman.posisi.x, tlTombolTutupHalaman.posisi.y);\n\n    fBuatHalaman(lebarLayar, tinggiLayar);\n}\n\n\n\n\nfunction fAturTataLetakLanskap(lebarLayar, tinggiLayar) {\n    mLog.jejak('mengatur tata letak lanskap halaman sudah_buka_peti');\n    // TODO\n    throw new Error('belum dimplementasikan');\n}\n\n\n\n\n__ekspor('aturTataLetak', (lebarLayar, tinggiLayar) => {\n    if (lebarLayar >= tinggiLayar) {\n        fAturTataLetakLanskap(lebarLayar, tinggiLayar);\n    } else {\n        fAturTataLetakPotret(lebarLayar, tinggiLayar);\n    }\n});\n"}, "konfig-notifikasi": {"halaman/konfig-notifikasi/indeks.css": "{{el}} {\n\n}\n", "halaman/konfig-notifikasi/indeks.html": "\n<div id=\"tutup_halaman\"></div>\n", "halaman/konfig-notifikasi/indeks.js": "const log = __impor('modul/0log');\n\n\nlog.info('memuat halaman konfig-notifikasi');\n", "halaman/konfig-notifikasi/tata_letak.js": "const mLog = __impor('modul/0log');\n\nconst mTombolTutupHalaman = __impor('modul/0tombol.tutup_halaman');\n\n\n\n\nconst tombolTutupHalaman = mTombolTutupHalaman.buat();\n\n\n\nfunction fAturTrei(lebarLayar, tinggiLayar) {\n    const gambarTreiAtas = __impor('aset/gambar/trei-atas-2.png');\n    const gambarTreiTengah1 = __impor('aset/gambar/trei-tengah-1.png');\n    const gambarTreiTengah2 = __impor('aset/gambar/trei-tengah-2.png');\n    const gambarTreiBawah = __impor('aset/gambar/trei-bawah-2.png');\n\n    const elTrei = document.createElement('div');\n    elTrei.style.position = 'absolute';\n    elTrei.style.top = '0';\n    elTrei.style.left = '0';\n    elTrei.style.width = '100%';\n    elTrei.style.height = '100%';\n    elTrei.style.margin = '0';\n    elTrei.style.padding = '0';\n\n    const elTreiAtas = document.createElement('img');\n    elTreiAtas.src = `data:image/png;ba