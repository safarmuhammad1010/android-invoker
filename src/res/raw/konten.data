lebarHalaman, tinggiHalaman) {\n    const lebarBaris = lebarHalaman;\n    const tinggiBaris = Math.floor(tinggiHalaman / 10);\n    const xBaris = 0;\n    const yBaris = Math.floor(tinggiBaris * indeks);\n\n    const ukuranNama = Math.floor(tinggiBaris * 0.30);\n    const xNama = Math.floor(lebarBaris * 0.05);\n    const yNama = Math.floor(tinggiBaris * 0.10);\n\n    const ukuranPutaran = Math.floor(tinggiBaris * 0.20);\n    const xPutaran = xNama;\n    const yPutaran = Math.floor(tinggiBaris * 0.60);\n\n    const elBaris = document.createElement('div');\n    elBaris.style.position = 'absolute';\n    elBaris.style.width = lebarBaris + 'px';\n    elBaris.style.height = tinggiBaris + 'px';\n    elBaris.style.left = xBaris + 'px';\n    elBaris.style.top = yBaris + 'px';\n    elHalaman.appendChild(elBaris);\n\n    const elTrei = document.createElement('img');\n    elTrei.src = __tema.gambar('treiA-1');\n    elTrei.style.position = 'absolute';\n    elTrei.style.width = lebarBaris + 'px';\n    elTrei.style.height = tinggiBaris + 'px';\n    elBaris.appendChild(elTrei);\n\n    const elNama = document.createElement('div');\n    elNama.innerHTML = riwayat.nama;\n    elNama.style.position = 'absolute';\n    elNama.style.left = xNama + 'px';\n    elNama.style.top = yNama + 'px';\n    elNama.style.fontFamily = __tema.teks('varianHuruf');\n    elNama.style.fontSize = ukuranNama + 'px';\n    elNama.style.color = __tema.warna('nilai');\n    elBaris.appendChild(elNama);\n\n    const elPutaran = document.createElement('div');\n    elPutaran.innerHTML = riwayat.putaran;\n    elPutaran.style.position = 'absolute';\n    elPutaran.style.left = xPutaran + 'px';\n    elPutaran.style.top = yPutaran + 'px';\n    elPutaran.style.fontFamily = __tema.teks('varianHuruf');\n    elPutaran.style.fontSize = ukuranPutaran + 'px';\n    elPutaran.style.color = __tema.warna('tersier');\n    elBaris.appendChild(elPutaran);\n}\n\n\n\nfunction fBuatHalaman(lebarLayar, tinggiLayar) {\n    const lebarHalaman = Math.floor(lebarLayar * 0.895);\n    const tinggiHalaman = Math.floor(tinggiLayar * 0.895);\n    const xHalaman = Math.floor(lebarLayar * 0.055);\n    const yHalaman = Math.floor(tinggiLayar * 0.080);\n\n    const elHalaman = document.createElement('div');\n    elHalaman.style.position = 'absolute';\n    elHalaman.style.width = lebarHalaman + 'px';\n    elHalaman.style.height = tinggiHalaman + 'px';\n    elHalaman.style.left = xHalaman + 'px';\n    elHalaman.style.top = yHalaman + 'px';\n    __el.appendChild(elHalaman);\n\n    __data.pantau('lotre_7H-riwayat', (_, data) => {\n        const lisRiwayat = JSON.parse(data);\n        for (let i = 0; i < lisRiwayat.length; i++) {\n            const riwayat = lisRiwayat[i];\n            fBuatBarisBaru(i, riwayat, elHalaman, lebarHalaman, tinggiHalaman);\n        }\n    });\n}\n\n\n\nfunction fAturTataLetakPotret(lebarLayar, tinggiLayar) {\n    mLog.jejak('mengatur tata letak potret halaman riwayat_lotre-7H');\n\n    fInisiasi(lebarLayar, tinggiLayar);\n    fAturTema(lebarLayar, tinggiLayar);\n\n    const ukuran = fHitungUkuran(lebarLayar, tinggiLayar);\n\n    const tlTombolTutupHalaman = fHitungTataLetakTombolTutupHalaman(ukuran);\n\n    tombolTutupHalaman.aturDimensi(tlTombolTutupHalaman.dimensi.lebar, tlTombolTutupHalaman.dimensi.tinggi);\n    tombolTutupHalaman.aturPosisi(tlTombolTutupHalaman.posisi.x, tlTombolTutupHalaman.posisi.y);\n\n    fBuatHalaman(lebarLayar, tinggiLayar)\n}\n\n\n\n\nfunction fAturTataLetakLanskap(lebarLayar, tinggiLayar) {\n    mLog.jejak('mengatur tata letak lanskap halaman riwayat_lotre-7H');\n    // TODO\n    throw new Error('belum dimplementasikan');\n}\n\n\n\n\n__ekspor('aturTataLetak', (lebarLayar, tinggiLayar) => {\n    if (lebarLayar >= tinggiLayar) {\n        fAturTataLetakLanskap(lebarLayar, tinggiLayar);\n    } else {\n        fAturTataLetakPotret(lebarLayar, tinggiLayar);\n    }\n});\n"}, "konfig-getar": {"halaman/konfig-getar/indeks.css": "{{el}} {\n\n}\n", "halaman/konfig-getar/indeks.html": "\n<div id=\"tutup_halaman\"></div>\n", "halaman/konfig-getar/indeks.js": "const log = __impor('modul/0log');\n\n\nlog.info('memuat halaman konfig-getar');\n", "halaman/konfig-getar/tata_letak.js": "const mLog = __impor('modul/0log');\n\nconst mTombolTutupHalaman = __impor('modul/0tombol.tutup_halaman');\n\n\n\n\nconst tombolTutupHalaman = mTombolTutupHalaman.buat();\n\n\n\nfunction fAturTrei(lebarLayar, tinggiLayar) {\n    const gambarTreiAtas = __impor('aset/gambar/trei-atas-2.png');\n    const gambarTreiTengah1 = __impor('aset/gambar/trei-tengah-1.png');\n    const gambarTreiTengah2 = __impor('aset/gambar/trei-tengah-2.png');\n    const gambarTreiBawah = __impor('aset/gambar/trei-bawah-2.png');\n\n    const elTrei = document.createElement('div');\n    elTrei.style.position = 'absolute';\n    elTrei.style.top = '0';\n    elTrei.style.left = '0';\n    elTrei.style.width = '100%';\n    elTrei.style.height = '100%';\n    elTrei.style.margin = '0';\n    elTrei.style.padding = '0';\n\n    const elTreiAtas = document.createElement('img');\n    elTreiAtas.src = `data:image/png;base64,${gambarTreiAtas}`;\n    elTreiAtas.style.display = 'block';\n    elTreiAtas.style.width = '100%';\n    elTreiAtas.style.height = '15%';\n    elTreiAtas.style.margin = '0';\n    elTrei.appendChild(elTreiAtas);\n\n    const elTreiTengah1 = document.createElement('img');\n    elTreiTengah1.src = `data:image/png;base64,${gambarTreiTengah1}`;\n    elTreiTengah1.style.display = 'block';\n    elTreiTengah1.style.width = '100%';\n    elTreiTengah1.style.height = '35%';\n    elTreiTengah1.style.margin = '0';\n    elTrei.appendChild(elTreiTengah1);\n\n    const elTreiTengah2 = document.createElement('img');\n    elTreiTengah2.src = `data:image/png;base64,${gambarTreiTengah2}`;\n    elTreiTengah2.style.display = 'block';\n    elTreiTengah2.style.width = '100%';\n    elTreiTengah2.style.height = '35%';\n    elTreiTengah2.style.margin = '0';\n    elTrei.appendChild(elTreiTengah2);\n\n    const elTreiBawah = document.createElement('img');\n    elTreiBawah.src = `data:image/png;base64,${gambarTreiBawah}`;\n    elTreiBawah.style.display = 'block';\n    elTreiBawah.style.width = '100%';\n    elTreiBawah.style.height = '15%';\n    elTreiBawah.style.margin = '0';\n    elTrei.appendChild(elTreiBawah);\n\n    __el.prepend(elTrei);\n}\n\n\nfunction fAturTema(lebarLayar, tinggiLayar) {\n    __el.style.position = 'relative';\n    fAturTrei(lebarLayar, tinggiLayar);\n}\n\n\n\n\nfunction fInisiasi(lebarLayar, tinggiLayar) {\n    tombolTutupHalaman.inisiasi(__el.querySelector('#tutup_halaman'), lebarLayar, tinggiLayar);\n}\n\n\n\nfunction fHitungTataLetakTombolTutupHalaman(ukuran) {\n    return {\n        dimensi: {\n            lebar: ukuran.ukuranTombolTutupHalaman,\n            tinggi: ukuran.ukuranTombolTutupHalaman\n        },\n        posisi: {\n            x: ukuran.lebarLayar * 0.88,\n            y: ukuran.tinggiLayar * 0.02\n        }\n    };\n}\n\n\n\nfunction fBuatTeks(elHalaman, tl) {\n    const elTeks = document.createElement('div');\n    elTeks.style.position = 'absolute';\n    elTeks.style.width = tl.lebarTeks + 'px';\n    elTeks.style.height = 'auto';\n    elTeks.style.left = tl.xTeks + 'px';\n    elTeks.style.top = tl.yTeks + 'px';\n    elTeks.style.fontSize = tl.ukuranTeks + 'px';\n    elTeks.style.fontFamily = __tema.teks('varianHuruf');\n    elTeks.style.color = __tema.warna('primer');\n    elTeks.innerHTML = 'Aktifkan getaran ?';\n    elHalaman.appendChild(elTeks);\n}\n\n\n\nfunction fBuatTombol(elHalaman, tl) {\n    let statusNyala = (__data.ambil('konfig.getar') == 'ya');\n\n    const elTombolYes = document.createElement('img');\n    elTombolYes.style.position = 'absolute';\n    elTombolYes.style.width = tl.lebarTombol + 'px';\n    elTombolYes.style.height = tl.tinggiTombol + 'px';\n    elTombolYes.style.right = tl.xTombolYes + 'px';\n    elTombolYes.style.bottom = tl.yTombolYes + 'px';\n    elTombolYes.src = statusNyala ? __tema.gambar('tombol-yes-3') : __tema.gambar('tombol-yes-1');\n    elHalaman.appendChild(elTombolYes);\n\n    const elTombolNo = document.createElement('img');\n    elTombolNo.style.position = 'absolute';\n    elTombolNo.style.width = tl.lebarTombol + 'px';\n    elTombolNo.style.height = tl.tinggiTombol + 'px';\n    elTombolNo.style.left = tl.xTombolNo + 'px';\n    elTombolNo.style.bottom = tl.yTombolNo + 'px';\n    elTombolNo.src = statusNyala ? __tema.gambar('tombol-no-1') : __tema.gambar('tombol-no-3');\n    elHalaman.appendChild(elTombolNo);\n\n    elTombolYes.addEventListener('click', () => {\n        if (statusNyala) return;\n        statusNyala = true;\n        elTombolYes.src = __tema.gambar('tombol-yes-2');\n        setTimeout(() => {\n            elTombolNo.src = __tema.gambar('tombol-no-1');\n            elTombolYes.src = __tema.gambar('tombol-yes-3');\n            __data.simpan('konfig.getar', 'ya');\n        }, 200);\n    });\n\n    elTombolNo.addEventListener('click', () => {\n        if (! statusNyala) return;\n        statusNyala = false;\n        elTombolNo.src = __tema.gambar('tombol-no-2');\n        setTimeout(() => {\n            elTombolYes.src = __tema.gambar('tombol-yes-1');\n            elTombolNo.src = __tema.gambar('tombol-no-3');\n            __data.simpan('konfig.getar', 'no');\n        }, 200);\n    });\n}\n\n\n\nfunction fBuatHalaman(tl) {\n    const elHalaman = document.createElement('div');\n    elHalaman.style.position = 'absolute';\n    elHalaman.style.width = tl.lebarHalaman + 'px';\n    elHalaman.style.height = tl.tinggiHalaman + 'px';\n    elHalaman.style.left = tl.xHalaman + 'px';\n    elHalaman.style.top = tl.yHalaman + 'px';\n    __el.appendChild(elHalaman);\n\n    fBuatTeks(elHalaman, tl);\n    fBuatTombol(elHalaman, tl);\n}\n\n\n\nfunction fHitungUkuran(lebarLayar, tinggiLayar) {\n    let marginX,\n        marginY,\n        spasiX,\n        spasiY,\n\n        lebarHalaman,\n        tinggiHalaman,\n        xHalaman,\n        yHalaman,\n\n        ukuranTombolTutupHalaman,\n\n        ukuranTeks,\n        lebarTeks,\n        xTeks,\n        yTeks,\n\n        lebarTombol,\n        tinggiTombol,\n\n        xTombolYes,\n        yTombolYes,\n\n        xTombolNo,\n        yTombolNo;\n\n    if (lebarLayar > tinggiLayar) {\n        // TODO\n        throw new Error('belum dimplementasikan');\n    } else {\n        marginX = 5;\n        marginY = 20;\n        spasiX = 5;\n        spasiY = 10;\n\n        ukuranTombolTutupHalaman = Math.min(30, Math.round(Math.min(lebarLayar, tinggiLayar) * 0.15));\n\n        lebarHalaman = Math.floor(lebarLayar * 0.895);\n        tinggiHalaman = Math.floor(tinggiLayar * 0.895);\n        xHalaman = Math.floor(lebarLayar * 0.055);\n        yHalaman = Math.floor(tinggiLayar * 0.080);\n\n        ukuranTeks = __tema.teks('ukuranHuruf');\n        lebarTeks = Math.floor(lebarHalaman * 0.94);\n        xTeks = Math.floor(lebarHalaman * 0.03);\n        yTeks = xTeks;\n\n        lebarTombol = Math.floor(lebarHalaman * 0.20);\n        tinggiTombol = Math.floor(tinggiHalaman * 0.10);\n\n        xTombolYes = Math.floor(lebarHalaman * 0.10); // right\n        yTombolYes = Math.floor(tinggiHalaman * 0.05); // bottom\n\n        xTombolNo = Math.floor(lebarHalaman * 0.10); // left\n        yTombolNo = yTombolYes;\n    }\n\n    return {\n        lebarLayar,\n        tinggiLayar,\n\n        marginX,\n        marginY,\n        spasiX,\n        spasiY,\n\n        lebarHalaman,\n        tinggiHalaman,\n        xHalaman,\n        yHalaman,\n\n        ukuranTombolTutupHalaman,\n\n        ukuranTeks,\n        lebarTeks,\n        xTeks,\n        yTeks,\n\n        lebarTombol,\n        tinggiTombol,\n\n        xTombolYes,\n        yTombolYes,\n\n        xTombolNo,\n        yTombolNo,\n    };\n}\n\n\n\nfunction fAturTataLetakPotret(lebarLayar, tinggiLayar) {\n    mLog.jejak('mengatur tata letak potret halaman konfig-getar');\n\n    fInisiasi(lebarLayar, tinggiLayar);\n    fAturTema(lebarLayar, tinggiLayar);\n\n    const tl = fHitungUkuran(lebarLayar, tinggiLayar);\n\n    const tlTombolTutupHalaman = fHitungTataLetakTombolTutupHalaman(tl);\n\n    tombolTutupHalaman.aturDimensi(tlTombolTutupHalaman.dimensi.lebar, tlTombolTutupHalaman.dimensi.tinggi);\n    tombolTutupHalaman.aturPosisi(tlTombolTutupHalaman.posisi.x, tlTombolTutupHalaman.posisi.y);\n\n    fBuatHalaman(tl);\n}\n\n\n\n\nfunction fAturTataLetakLanskap(lebarLayar, tinggiLayar) {\n    mLog.jejak('mengatur tata letak lanskap halaman konfig-getar');\n    // TODO\n    throw new Error('belum dimplementasikan');\n}\n\n\n\n\n__ekspor('aturTataLetak', (lebarLayar, tinggiLayar) => {\n    if (lebarLayar >= tinggiLayar) {\n        fAturTataLetakLanskap(lebarLayar, tinggiLayar);\n    } else {\n        fAturTataLetakPotret(lebarLayar, tinggiLayar);\n    }\n});\n"}}, "aset": {"aset/gambar/border_profil.png": "", "aset/gambar/foto_profil.png": "", "aset/gambar/hud-a.png": "", "aset/gambar/hud-b.png": "", "aset/gambar/ikon-dadu.png": "", "aset/gambar/ikon-email.png": "", "aset/gambar/ikon-gagal-1.png": "", "aset/gambar/ikon-harga.png": "", "aset/gambar/ikon-insentif.png": "", "aset/gambar/ikon-lotre.png": "", "aset/gambar/ikon-market.png": "", "aset/gambar/ikon-misi.png": "", "aset/gambar/ikon-panah.png": "", "aset/gambar/ikon-peti.png": "", "aset/gambar/ikon-referal.png": "", "aset/gambar/ikon-tidak.png": "", "aset/gambar/ikon-tiket.png": "", "aset/gambar/ikon-ya.png": "", "aset/gambar/ikon_berhasil.png": "", "aset/gambar/ikon_gagal.png": "", "aset/gambar/ikon_link-1.png": "", "aset/gambar/ikon_lotre-hadiah.png": "", "aset/gambar/ikon_lotre-judul.png": "", "aset/gambar/ikon_lotre-timer.png": "", "aset/gambar/ikon_status_misi-gagal.png": "", "aset/gambar/ikon_status_misi-selesai.png": "", "aset/gambar/ikon_warning.png": "", "aset/gambar/ikut-1.png": "", "aset/gambar/ikut-2.png": "", "aset/gambar/ikut-3.png": "", "aset/gambar/input-1.png": "", "aset/gambar/input-2.png": "", "aset/gambar/input-kode-1.png": "", "aset/gambar/input-kod