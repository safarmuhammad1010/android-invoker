, lebarLayar, tinggiLayar) {\n    el.innerHTML = '';\n}\n\n\nfunction fAturTema(el, lebarLayar, tinggiLayar, f) {\n    const gambarLatar1 = __impor('aset/gambar/tmb-tutup-1.png');\n    const gambarLatar2 = __impor('aset/gambar/tmb-tutup-2.png');\n    const gambarNormal = `data:image/png;base64,${gambarLatar1}`;\n    const gambarDitekan = `data:image/png;base64,${gambarLatar2}`;\n\n    const elLatar = document.createElement('img');\n    elLatar.src = gambarNormal;\n    elLatar.style.width = '100%';\n    elLatar.style.height = '100%';\n\n    el.addEventListener('click', () => {\n        elLatar.src = gambarDitekan;\n        setTimeout(() => {\n            elLatar.src = gambarNormal;\n            if (f)\n                f();\n            else\n                fSaatDitekan();\n        }, __tema.animasi('jeda_tombol_ditekan'));\n    });\n    el.appendChild(elLatar);\n}\n\n\nfunction fBuat(f) {\n    let el = null;\n    return {\n        inisiasi: (_el, lebarLayar, tinggiLayar) => {\n            if (!_el) {\n                throw new Error('parameter invalid: _el tiada');\n            }\n            el = _el;\n            el.style.position = 'fixed';\n            fInisiasi(_el, lebarLayar, tinggiLayar);\n            fAturTema(el, lebarLayar, tinggiLayar, f);\n        },\n        aturDimensi: (lebar, tinggi) => {\n            if (!el) {\n                throw new Error('algoritma invalid: __el tiada');\n            }\n            el.style.width = lebar + 'px';\n            el.style.height = tinggi + 'px';\n        },\n        aturPosisi: (x, y) => {\n            if (!el) {\n                throw new Error('algoritma invalid: __el tiada');\n            }\n            el.style.left = x + 'px';\n            el.style.top = y + 'px';\n        }\n    };\n}\n\n\n__ekspor('buat', fBuat);\n"}, "error": {"modul/error/index.js": "\n\nconst mSkroller =  __impor('modul/0skroller');\n\n\n\n\nconst el = document.createElement('div');\ndocument.body.appendChild(el);\n\n\n\nlet elKonten;\nl