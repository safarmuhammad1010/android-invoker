.style.display = 'inline-block';\n    elTeksWarning.style.marginLeft = tl.spasiTeksSalah + 'px';\n    elTeksWarning.style.fontSize = tl.ukuranTeksSalah + 'px';\n    elTeksWarning.style.fontFamily = __tema.teks('varianHuruf');\n    elTeksWarning.style.color = __tema.warna('error');\n    elTeksWarning.innerHTML = 'Kode Salah [1/3]';\n    elWarning.appendChild(elTeksWarning);\n}\n\n\n\nfunction fBuatHalaman1(tl) {\n    elHalaman1 = document.createElement('div');\n    elHalaman1.style.position = 'absolute';\n    elHalaman1.style.width = tl.lebarHalaman + 'px';\n    elHalaman1.style.height = tl.tinggiHalaman + 'px';\n    elHalaman1.style.left = tl.xHalaman + 'px';\n    elHalaman1.style.top = tl.yHalaman + 'px';\n    __el.appendChild(elHalaman1);\n\n    fBuatTeks(elHalaman1, tl);\n    fBuatInput(elHalaman1, tl);\n    fBuatPapanKetik(elHalaman1, tl);\n    fBuatWarning(elHalaman1, tl);\n}\n\n\n\nfunction fBuatHalaman2(tl) {\n    elHalaman2 = document.createElement('div');\n    elHalaman2.style.display = 'none';\n    elHalaman2.style.position = 'absolute';\n    elHalaman2.style.width = tl.lebarHalaman + 'px';\n    elHalaman2.style.height = tl.tinggiHalaman + 'px';\n    elHalaman2.style.left = tl.xHalaman + 'px';\n    elHalaman2.style.top = tl.yHalaman + 'px';\n    __el.appendChild(elHalaman2);\n\n    const elHal2_Logo = document.createElement('img');\n    elHal2_Logo.style.position = 'absolute';\n    elHal2_Logo.style.width = tl.lebarLogoHal2 + 'px';\n    elHal2_Logo.style.height = tl.tinggiLogoHal2 + 'px';\n    elHal2_Logo.style.transform = 'translate(-50%, 0)';\n    elHal2_Logo.style.left = tl.xLogoHal2 + 'px';\n    elHal2_Logo.style.top = tl.yLogoHal2 + 'px';\n    elHal2_Logo.style.opacity = '0.7';\n    elHal2_Logo.src = __tema.gambar('logo_warning');\n    elHalaman2.appendChild(elHal2_Logo);\n\n    const elHal2_Teks = document.createElement('div');\n    elHal2_Teks.style.position = 'absolute';\n    elHal2_Teks.style.width = tl.lebarTeksHal2 + 'px';\n    elHal2_Teks.style