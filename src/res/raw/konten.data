onst jumlahKartuV = 6;\n    const jumlahKartu = jumlahKartuH * jumlahKartuV;\n\n    const lebarKartu = Math.floor(lebarKontener / jumlahKartuH);\n    const tinggiKartu = Math.floor(tinggiKontener / jumlahKartuV);\n\n    const lisXKartu = [];\n    const lisYKartu = [];\n\n    let index = 0;\n    for (let baris = 0; baris < jumlahKartuV; baris++) {\n        for (let kolom = 0; kolom < jumlahKartuH; kolom++) {\n            const x = Math.floor(kolom * lebarKartu);\n            const y = Math.floor(baris * tinggiKartu);\n            lisXKartu[index] = x;\n            lisYKartu[index] = y;\n            index += 1;\n        }\n    }\n\n    return {\n        jumlahKartu,\n        jumlahKartuH,\n        jumlahKartuV,\n        lebarKartu,\n        tinggiKartu,\n        lisXKartu,\n        lisYKartu,\n    };\n}\n\n\n\nfunction fBuatKartuBelakang(lebarKartu, tinggiKartu) {\n    const elKartuBelakang = document.createElement('img');\n\n    elKartuBelakang.src = __tema.gambar('kartu.belakang-1');\n    elKartuBelakang.style.width = lebarKartu + 'px';\n    elKartuBelakang.style.height = tinggiKartu + 'px';\n\n    return elKartuBelakang;\n}\n\n\n\nfunction fBuatKartuDepan(lebarKartu, tinggiKartu) {\n    const elKartuDepan = document.createElement('img');\n\n    elKartuDepan.style.width = lebarKartu + 'px';\n    elKartuDepan.style.height = tinggiKartu + 'px';\n\n    return elKartuDepan;\n}\n\n\n\nfunction fRenderDaftarKartu(el, lebarKontener, tinggiKontener) {\n    const lisKartu = [];\n    const tl = fHitungTataLetak(lebarKontener, tinggiKontener);\n\n    for (let i = 0; i < tl.jumlahKartu; i++) {\n        const padding = 2;\n        const paddingX = Math.floor(padding / 2);\n        const paddingY = Math.floor(padding / 2);\n\n        const lebarKartu = Math.floor(tl.lebarKartu - padding);\n        const tinggiKartu = Math.floor(tl.tinggiKartu - padding);\n\n        const xKartu = tl.lisXKartu[i];\n        const yKartu = tl.lisYKartu[i];\n\n        const elKontenerKartu = document.createElement('div');\n        elKontenerKartu.style.position = 'absolute';\n        elKontenerKartu.style.width = tl.lebarKartu + 'px';\n        elKontenerKartu.style.height = tl.tinggiKartu + 'px';\n        elKontenerKartu.style.left = xKartu + 'px';\n        elKontenerKartu.style.top = yKartu + 'px';\n        el.appendChild(elKontenerKartu);\n\n        const elKartuDepan = fBuatKartuDepan(lebarKartu, tinggiKartu);\n        elKartuDepan.style.position = 'absolute';\n        elKartuDepan.style.left = paddingX + 'px';\n        elKartuDepan.style.top = paddingY + 'px';\n        elKontenerKartu.appendChild(elKartuDepan);\n\n        const elKartuBelakang = fBuatKartuBelakang(lebarKartu, tinggiKartu);\n        elKartuBelakang.style.position = 'absolute';\n        elKartuBelakang.style.left = paddingX + 'px';\n        elKartuBelakang.style.top = paddingY + 'px';\n        elKontenerKartu.appendChild(elKartuBelakang);\n\n        const kartu = {\n            index: i,\n            elKontenerKartu,\n            elKartuBelakang,\n            elKartuDepan,\n        };\n        lisKartu.push(kartu);\n    }\n\n    return lisKartu;\n}\n\n\n\nfunction fAturNamaKartu(kartuTerpilih, lisKartu) {\n    const lisAcakNamaKartu = [];\n    if (kartuTerpilih.nama == 'A') {\n        for (let i = 0; i < 30; i++) {\n            lisAcakNamaKartu.push('D');\n        }\n        lisAcakNamaKartu.push('C');\n        lisAcakNamaKartu.push('C');\n        lisAcakNamaKartu.push('C');\n        lisAcakNamaKartu.push('B');\n        lisAcakNamaKartu.push('B');\n    } else if (kartuTerpilih.nama == 'B') {\n        for (let i = 0; i < 30; i++) {\n            lisAcakNamaKartu.push('D');\n        }\n        lisAcakNamaKartu.push('C');\n        lisAcakNamaKartu.push('C');\n        lisAcakNamaKartu.push('C');\n        lisAcakNamaKartu.push('B');\n        lisAcakNamaKartu.push('A');\n    } else if (kartuTerpilih.nama == 'C') {\n        for (let i = 0; i < 30; i++) {\n            lisAcakNamaKartu.push('D');\n        }\n        lisAcakNamaKartu.push('C');\n        lisAcakNamaKartu.push('C');\n        lisAcakNamaKartu.push('B');\n        lisAcakNamaKartu.push('B');\n        lisAcakNamaKartu.push('A');\n    } else if (kartuTerpilih.nama == 'D') {\n        for (let i = 0; i < 29; i++) {\n            lisAcakNamaKartu.push('D');\n        }\n        lisAcakNamaKartu.push('C');\n        lisAcakNamaKartu.push('C');\n        lisAcakNamaKartu.push('C');\n        lisAcakNamaKartu.push('B');\n        lisAcakNamaKartu.push('B');\n        lisAcakNamaKartu.push('A');\n    } else {\n        const s = 'algoritma invalid: nama kartu invalid';\n        console.error(s);\n        throw new Error(s);\n    }\n\n    shuffleArray(lisAcakNamaKartu);\n\n    for (let i = 0; i < lisKartu.length; i++) {\n        const kartu = lisKartu[i];\n        if (kartu === kartuTerpilih) {\n            kartu.elKartuDepan.src = __tema.gambar('kartu.depan.' + kartuTerpilih.nama + '-2');\n        } else {\n            kartu.nama = lisAcakNamaKartu.pop();\n            kartu.elKartuDepan.src = __tema.gambar('kartu.depan.' + kartu.nama + '-1');\n        }\n    }\n\n    console.log(lisKartu);\n}\n\n\n\n\nfunction fBukaKartu(kartuTerpilih, lisKartu, fSelesai) {\n    console.log('membuka kartu', JSON.stringify(kartuTerpilih));\n\n    fSelesaiBukaKartu = fSelesai;\n\n    fAturNamaKartu(kartuTerpilih, lisKartu);\n\n    function fRenderBuka(index) {\n        const kartu = lisKartu[index];\n        if (index == (lisKartu.length)) {\n            setTimeout(() => {\n                kartuTerpilih.elKartuDepan.innerHTML = kartuTerpilih.nama;\n                kartuTerpilih.elKartuBelakang.style.display = 'none';\n\n                fSelesai();\n            }, 150);\n            return;\n        }\n\n        if (kartu !== kartuTerpilih) {\n            kartu.elKartuBelakang.style.display = 'none';\n        }\n\n        setTimeout(() => {\n            fRenderBuka(index+1);\n        }, 150);\n    }\n\n    fRenderBuka(0);\n}\n\n\n\nfuncti