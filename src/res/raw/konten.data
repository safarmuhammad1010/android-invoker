\n        posisi: {\n            x: ukuran.lebarLayar * 0.88,\n            y: ukuran.tinggiLayar * 0.02\n        }\n    };\n}\n\n\n\nfunction fHitungUkuran(lebarLayar, tinggiLayar) {\n    let marginX,\n        marginY,\n        spasiX,\n        spasiY,\n        ukuranTombolTutupHalaman;\n\n    if (lebarLayar > tinggiLayar) {\n        // TODO\n        throw new Error('belum dimplementasikan');\n    } else {\n        marginX = 5;\n        marginY = 20;\n        spasiX = 5;\n        spasiY = 10;\n\n        ukuranTombolTutupHalaman = Math.min(30, Math.round(Math.min(lebarLayar, tinggiLayar) * 0.15));\n    }\n\n    return {\n        lebarLayar,\n        tinggiLayar,\n        marginX,\n        marginY,\n        spasiX,\n        spasiY,\n        ukuranTombolTutupHalaman\n    };\n}\n\n\n\nfunction fBuatBarisBaru(indeks, riwayat, elHalaman, lebarHalaman, tinggiHalaman) {\n    const lebarBaris = lebarHalaman;\n    const tinggiBaris = Math.floor(tinggiHalaman / 10);\n    const xBaris = 0;\n    const yBaris = Math.floor(tinggiBaris * indeks);\n\n    const ukuranNama = Math.floor(tinggiBaris * 0.30);\n    const xNama = Math.floor(lebarBaris * 0.05);\n    const yNama = Math.floor(tinggiBaris * 0.10);\n\n    const ukuranPutaran = Math.floor(tinggiBaris * 0.20);\n    const xPutaran = xNama;\n    const yPutaran = Math.floor(tinggiBaris * 0.60);\n\n    const elBaris = document.createElement('div');\n    elBaris.style.position = 'absolute';\n    elBaris.style.width = lebarBaris + 'px';\n    elBaris.style.height = tinggiBaris + 'px';\n    elBaris.style.left = xBaris + 'px';\n    elBaris.style.top = yBaris + 'px';\n    elHalaman.appendChild(elBaris);\n\n    const elTrei = document.createElement('img');\n    elTrei.src = __tema.gambar('treiA-1');\n    elTrei.style.position = 'absolute';\n    elTrei.style.width = lebarBaris + 'px';\n    elTrei.style.height = tinggiBaris + 'px';\n    elBaris.appendChild(elTrei);\n\n    const elNama = document.createElement('div');\n    elNama.innerHTML = r