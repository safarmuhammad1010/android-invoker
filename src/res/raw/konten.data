 = __tema.teks('varianHuruf');\n    elKonten.innerHTML = 'permintaan sedang diproses';\n}\n\n\n\nfunction fAturTema(lebarLayar, tinggiLayar) {\n    el.style.width = lebarLayar + 'px';\n    el.style.height = tinggiLayar + 'px';\n    el.style.zIndex = 9999;\n    el.style.display = 'none';\n    el.style.position = 'fixed';\n    el.style.left = '0';\n    el.style.top = '0';\n\n    fAturTrei(lebarLayar, tinggiLayar);\n    fAturTombolOK(lebarLayar, tinggiLayar);\n\n    const lebarHalaman = Math.floor(lebarLayar * 0.895);\n    const tinggiHalaman = Math.floor(tinggiLayar * 0.825);\n    const xHalaman = Math.floor(lebarLayar * 0.055);\n    const yHalaman = Math.floor(tinggiLayar * 0.030);\n\n    fBuatHalaman(lebarHalaman, tinggiHalaman, xHalaman, yHalaman);\n}\n\n\n\nfAturTema(window.innerWidth, window.innerHeight);\n\n\n\n\n\nfunction fTampilkan() {\n    __nonaktifkan_halaman();\n    el.style.display = 'block';\n    __saat_mundur.push(fSembunyikan);\n}\n\n\nfunction fSembunyikan() {\n    el.style.display = 'none';\n    __aktifkan_halaman();\n}\n\n\n\n__ekspor('tampilkan', fTampilkan);\n"}, "etalase.inventori": {"modul/etalase.inventori/indeks.js": "\nconst gambarLatar1 = __impor('aset/gambar/tmb-inventori-1.png');\nconst gambarLatar2 = __impor('aset/gambar/tmb-inventori-2.png');\n\n\nlet elLatar;\nlet elJumlahInventori;\n\n\nfunction fAturUkuranDanPosisiTeks(lebarKontener, tinggiKontener) {\n    if (!elJumlahInventori) return;\n\n    const ukuranTeks = Math.floor(tinggiKontener * 0.1);\n    const yTeks = ukuranTeks;\n    const xTeks = Math.floor((lebarKontener / 2));\n\n    elJumlahInventori.style.position = 'absolute';\n    elJumlahInventori.style.fontSize = elJumlahInventori.style.lineHeight = ukuranTeks + 'px';\n    elJumlahInventori.style.transform = 'translate(50%, 0)';\n    elJumlahInventori.style.top = yTeks + 'px';\n    elJumlahInventori.style.right = xTeks + 'px';\n    elJumlahInventori.style.padding = 0;\n    elJumlahInventori.style.margin = 0;\n    elJumlahInven