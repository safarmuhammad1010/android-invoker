ta', (_, teks) => {\n        elKonten.innerHTML = __data.ambil('profil.biodata');\n    });\n}\n\n\nfunction fHitungUkuran(lebarKontener, tinggiKontener) {\n    const marginX = 5;\n    const marginY = 5;\n    const spasiX = 4;\n    const spasiY = 5;\n\n    const lebarKonten = lebarKontener - (marginX * 2);\n    const ukuranHurufKonten = 20;\n\n\n    // Foto Profil:\n    // --------------------------------------------------------------------------\n    const lebarLatarFotoProfil = Math.floor((lebarKonten / 2) - (spasiX / 2));\n    const tinggiLatarFotoProfil = Math.floor((tinggiKontener / 3) - marginY);\n    const xLatarFotoProfil = marginX;\n    const yLatarFotoProfil = marginY;\n\n    const lebarFremFotoProfil = Math.floor(lebarLatarFotoProfil * 0.02);\n\n    const lebarKontenFotoProfil = lebarLatarFotoProfil - (lebarFremFotoProfil * 2);\n    const tinggiKontenFotoProfil = tinggiLatarFotoProfil - (lebarFremFotoProfil * 2);\n    const xKontenFotoProfil = xLatarFotoProfil + lebarFremFotoProfil;\n    const yKontenFotoProfil = yLatarFotoProfil + lebarFremFotoProfil;\n    // --------------------------------------------------------------------------\n\n\n    // Gender:\n    // --------------------------------------------------------------------------\n    const lebarLatarGender = lebarLatarFotoProfil;\n    const tinggiLatarGender = Math.floor((tinggiLatarFotoProfil / 2) - (spasiY / 2));\n    const xLatarGender = marginX + lebarLatarFotoProfil + spasiX;\n    const yLatarGender = marginY;\n    // --------------------------------------------------------------------------\n\n\n    // Umur:\n    // --------------------------------------------------------------------------\n    const lebarLatarUmur = lebarLatarGender;\n    const tinggiLatarUmur = tinggiLatarGender;\n    const xLatarUmur = xLatarGender;\n    const yLatarUmur = marginY + tinggiLatarGender + spasiY;\n    // --------------------------------------------------------------------------\n\n\n    // Nama:\n    // --------------------------------------------------------------------------\n    const lebarLatarNama = lebarKonten;\n    const tinggiLatarNama = ukuranHurufKonten * 2;\n    const xLatarNama = marginX;\n    const yLatarNama = Math.floor(tinggiKontener / 3) + spasiY;\n\n    const lebarFremNama = Math.floor(tinggiLatarNama * 0.1);\n\n    const ukuranHurufKontenNama = ukuranHurufKonten;\n    const xKontenNama = xLatarNama + Math.floor(lebarLatarNama * 0.15);\n    const yKontenNama = yLatarNama + lebarFremNama;\n    // --------------------------------------------------------------------------\n\n\n    // Provinsi:\n    // --------------------------------------------------------------------------\n    const lebarLatarProvinsi = lebarLatarNama;\n    const tinggiLatarProvinsi = tinggiLatarNama;\n    const xLatarProvinsi = xLatarNama;\n    const yLatarProvinsi = yLatarNama + tinggiLatarNama + spasiY;\n\n    const lebarFremProvinsi = Math.floor(tinggiLatarProvinsi * 0.1);\n\n    const ukuranHurufKontenProvinsi = ukuranHurufKonten;\n    const xKontenProvinsi = xLatarProvinsi + Math.floor(lebarLatarProvinsi * 0.15);\n    const yKontenProvinsi = yLatarProvinsi + lebarFremProvinsi;\n    // --------------------------------------------------------------------------\n\n\n    // Biodata:\n    // --------------------------------------------------------------------------\n    const lebarLatarBiodata = lebarLatarNama;\n    const tinggiLatarBiodata = tinggiKontener - marginY - tinggiLatarFotoProfil - spasiY - tinggiLatarNama - spasiY - tinggiLatarProvinsi - spasiY - marginY;\n    const xLatarBiodata = xLatarNama;\n    const yLatarBiodata = yLatarNama + tinggiLatarNama + spasiY + tinggiLatarProvinsi + spasiY;\n\n    const lebarFremBiodata = Math.floor(lebarLatarBiodata * 0.02);\n\n    const ukuranHurufKontenBiodata = ukuranHurufKonten;\n    const lebarKontenBiodata = Math.floor(lebarLatarBiodata * 0.96);\n    const tinggiKontenBiodata = Math.floor(tinggiLatarBiodata * 0.96);\n    const xKontenBiodata = marginX + lebarFremBiodata;\n    const yKontenBiodata = yLatarBiodata + lebarFremBiodata;\n    // --------------------------------------------------------------------------\n\n\n    return {\n        lebarLatarFotoProfil,\n        tinggiLatarFotoProfil,\n        xLatarFotoProfil,\n        yLatarFotoProfil,\n        lebarKontenFotoProfil,\n        tinggiKontenFotoProfil,\n        xKontenFotoProfil,\n        yKontenFotoProfil,\n\n        lebarLatarGender,\n        tinggiLatarGender,\n        xLatarGender,\n        yLatarGender,\n\n        lebarLatarUmur,\n        tinggiLatarUmur,\n        xLatarUmur,\n        yLatarUmur,\n\n        lebarLatarNama,\n        tinggiLatarNama,\n        xLatarNama,\n        yLatarNama,\n        ukuranHurufKontenNama,\n        xKontenNama,\n        yKontenNama,\n\n        lebarLatarProvinsi,\n        tinggiLatarProvinsi,\n        xLatarProvinsi,\n        yLatarProvinsi,\n        ukuranHurufKontenProvinsi,\n        xKontenProvinsi,\n        yKontenProvinsi,\n\n        lebarLatarBiodata,\n        tinggiLatarBiodata,\n        xLatarBiodata,\n        yLatarBiodata,\n        ukuranHurufKontenBiodata,\n        lebarKontenBiodata,\n        tinggiKontenBiodata,\n        xKontenBiodata,\n        yKontenBiodata,\n    };\n}\n\n\nfunction fBuat(lebarKontener, tinggiKontener) {\n    const elKontener = document.createElement('div');\n    elKontener.style.width = lebarKontener + 'px';\n    elKontener.style.height = tinggiKontener + 'px';\n    elKontener.style.position = 'relative';\n\n    const ukuran= fHitungUkuran(lebarKontener, tinggiKontener);\n\n\n    fBuatFotoProfil(elKontener, ukuran);\n    fBuatKolomGender(elKontener, ukuran);\n    fBuatKolomUmur(elKontener, ukuran);\n    fBuatBarisNama(elKontener, ukuran);\n    fBuatBarisProvinsi(elKontener, ukuran);\n    fBuatBarisBiodata(elKontener, ukuran);\n\n    return elKontener;\n}\n\n\n__ekspor('buat', fBuat);\n"}, "papan_ketik-login-nama": {"modul/papan_ketik-login-nama/indeks.js": "\n\n\nfunctio