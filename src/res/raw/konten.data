ut.appendChild(elFremTeks);\n\n    const elTeks = document.createElement('div');\n    elTeks.style.position = 'absolute';\n    elTeks.style.minWidth = lebarTeks + 'px';\n    elTeks.style.height = '100%';\n    elTeks.style.right = '0';\n    elTeks.style.fontSize = __tema.teks('ukuranHuruf') + 'px';\n    elTeks.style.fontFamily = __tema.teks('varianHuruf');\n    elTeks.style.color = __tema.warna('teks');\n    elTeks.style.whiteSpace = \"pre\";\n    elTeks.innerHTML = teks;\n    elFremTeks.appendChild(elTeks);\n\n    let tas = teks;\n    let flop = false;\n    let pilih_semua = false;\n\n    setInterval(() => {\n        if (flop)\n            elTeks.innerHTML = tas + '|';\n        else\n            elTeks.innerHTML = tas + ' ';\n        flop = !flop;\n    }, 500);\n\n    function fPilihSemua() {\n        pilih_semua = true;\n        elTeks.style.backgroundColor = __tema.warna('tersier');\n    }\n\n    function fBatalPilih() {\n        pilih_semua = false;\n        elTeks.style.backgroundColor = '';\n    }\n\n    function fHapus() {\n        if (pilih_semua) {\n            tas = '';\n            elTeks.innerHTML = '|';\n            flop = !flop;\n            fBatalPilih();\n            return;\n        }\n        if (tas.length == 0) return;\n        tas = tas.slice(0, tas.length-1);\n        elTeks.innerHTML = tas + '|';\n        flop = !flop;\n    }\n\n    function fKetik(huruf) {\n        if (pilih_semua) {\n            fHapus();\n        }\n        tas += huruf;\n        elTeks.innerHTML = tas + '|';\n        flop = !flop;\n    }\n\n    function fAmbil() {\n        return tas;\n    }\n\n    return {\n        el: elInput,\n        fKetik,\n        fPilihSemua,\n        fHapus,\n        fAmbil,\n    };\n}\n\n\n\n__ekspor('buat', fBuat);\n"}, "input-2": {"modul/input-2/indeks.js": "\n\n\nfunction fBuat(teks, tl) {\n    const elInput = document.createElement('div');\n    elInput.style.position = 'relative';\n    elInput.style.width = tl.lebarInput + 'px';\n    elInput.s