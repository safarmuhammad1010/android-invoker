man(lebarLayar, tinggiLayar);\n}\n\n\n\n\nfunction fInisiasi(lebarLayar, tinggiLayar) {\n    tombolTutupHalaman.inisiasi(__el.querySelector('#tutup_halaman'), lebarLayar, tinggiLayar);\n}\n\n\n\nfunction fHitungTataLetakTombolTutupHalaman(ukuran) {\n    return {\n        dimensi: {\n            lebar: ukuran.ukuranTombolTutupHalaman,\n            tinggi: ukuran.ukuranTombolTutupHalaman\n        },\n        posisi: {\n            x: ukuran.lebarLayar * 0.88,\n            y: ukuran.tinggiLayar * 0.02\n        }\n    };\n}\n\n\n\nfunction fHitungUkuran(lebarLayar, tinggiLayar) {\n    let marginX,\n        marginY,\n        spasiX,\n        spasiY,\n        ukuranTombolTutupHalaman;\n\n    if (lebarLayar > tinggiLayar) {\n        // TODO\n        throw new Error('belum dimplementasikan');\n    } else {\n        marginX = 5;\n        marginY = 20;\n        spasiX = 5;\n        spasiY = 10;\n\n        ukuranTombolTutupHalaman = Math.min(30, Math.round(Math.min(lebarLayar, tinggiLayar) * 0.15));\n    }\n\n    return {\n        lebarLayar,\n        tinggiLayar,\n        marginX,\n        marginY,\n        spasiX,\n        spasiY,\n        ukuranTombolTutupHalaman\n    };\n}\n\n\n\n\nfunction fAturTataLetakPotret(lebarLayar, tinggiLayar) {\n    mLog.jejak('mengatur tata letak potret halaman profil');\n\n    fInisiasi(lebarLayar, tinggiLayar);\n    fAturTema(lebarLayar, tinggiLayar);\n\n    const ukuran = fHitungUkuran(lebarLayar, tinggiLayar);\n\n    const tlTombolTutupHalaman = fHitungTataLetakTombolTutupHalaman(ukuran);\n\n    tombolTutupHalaman.aturDimensi(tlTombolTutupHalaman.dimensi.lebar, tlTombolTutupHalaman.dimensi.tinggi);\n    tombolTutupHalaman.aturPosisi(tlTombolTutupHalaman.posisi.x, tlTombolTutupHalaman.posisi.y);\n}\n\n\n\n\nfunction fAturTataLetakLanskap(lebarLayar, tinggiLayar) {\n    mLog.jejak('mengatur tata letak lanskap halaman profil');\n    // TODO\n    throw new Error('belum dimplementasikan');\n}\n\n\n\n\n__ekspor('aturTataLetak', (lebarLayar, tinggi