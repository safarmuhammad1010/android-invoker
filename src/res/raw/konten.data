     xProduk = 0;\n    } else {\n        xProduk = lebarProduk;\n    }\n\n    const elProduk = document.createElement('div');\n    elProduk.style.position = 'absolute';\n    elProduk.style.width = lebarProduk + 'px';\n    elProduk.style.height = tinggiProduk + 'px';\n    elProduk.style.left = xProduk + 'px';\n    elProduk.style.top = yProduk + 'px';\n    elHalaman.appendChild(elProduk);\n\n    const lebarLogo = Math.floor(lebarProduk * 0.890);\n    const tinggiLogo = Math.floor(tinggiProduk * 0.73);\n    const xLogo = Math.floor(lebarProduk * 0.060);\n    const yLogo = Math.floor(tinggiProduk * 0.065);\n\n    const elLogo = document.createElement('img');\n    elLogo.style.position = 'absolute';\n    elLogo.style.width = lebarLogo + 'px';\n    elLogo.style.height = tinggiLogo + 'px';\n    elLogo.style.left = xLogo + 'px';\n    elLogo.style.top = yLogo + 'px';\n    elProduk.appendChild(elLogo);\n\n    if (data.ikon.startsWith('http://') || data.ikon.startsWith('https://')) {\n        elLogo.src = data.ikon;\n    } else {\n        elLogo.src = __tema.gambar(data.ikon);\n    }\n\n    const elTrei = document.createElement('img');\n    elTrei.style.position = 'absolute';\n    elTrei.style.width = '100%';\n    elTrei.style.height = '100%';\n    elTrei.src = __tema.gambar('latar_produk-1');\n    elProduk.appendChild(elTrei);\n\n\n    const teksHarga = __format_kredit(data.harga);\n\n    const ukuranTeks = Math.floor(tinggiProduk * 0.10);\n    const spasiX = Math.floor(ukuranTeks / 3);\n\n    const lebarFrem = Math.floor(lebarProduk * 0.90);\n    const tinggiFrem = ukuranTeks;\n    const xFrem = Math.floor(lebarProduk * 0.50);\n    const yFrem = Math.floor(tinggiProduk * 0.90);\n\n    const lebarIkonHarga = ukuranTeks;\n    const tinggiIkonHarga = lebarIkonHarga;\n\n    const elFrem = document.createElement('div');\n    elFrem.style.display = 'flex';\n    elFrem.style.flexWrap = 'nowrap';\n    elFrem.style.position = 'absolute';\n    elFrem.style.transform = 'translate(-50%,