barLayar * 0.055);\n        yHalaman = Math.floor(tinggiLayar * 0.080);\n\n        ukuranTeks = __tema.teks('ukuranHuruf');\n        lebarTeks = Math.floor(lebarHalaman * 0.94);\n        xTeks = Math.floor(lebarHalaman * 0.03);\n        yTeks = xTeks;\n\n        lebarPapanKetik = Math.floor(lebarHalaman * 1);;\n        xPapanKetik = Math.floor(lebarHalaman * 0);\n        yPapanKetik = Math.floor(tinggiHalaman * 0); // bottom\n\n        lebarInput = Math.floor(lebarHalaman / 5);\n        tinggiInput = lebarInput;\n        yInput = yTeks + ukuranTeks + Math.floor(tinggiInput / 4);\n\n        const spasi = Math.floor(lebarInput / 5);\n\n        xInput1 = spasi;\n        xInput2 = xInput1 + lebarInput + spasi;\n        xInput3 = xInput2 + lebarInput + spasi;\n        xInput4 = xInput3 + lebarInput + spasi;\n\n        lebarInputTeks = Math.floor(lebarInput * 0.80);\n        tinggiInputTeks = lebarInputTeks;\n        xInputTeks = Math.floor(lebarInput * 0.10);\n        yInputTeks = xInputTeks;\n\n        ukuranTeksInput = lebarInputTeks;\n\n        const topPapanKetik = tinggiHalaman - (Math.floor(lebarHalaman / 3) * 4 * 0.80);\n        const bottomInput = yInput + tinggiInput;\n        const tengahWarning = Math.floor((topPapanKetik - bottomInput) / 2);\n\n        xWarning = Math.floor(lebarHalaman * 0.50); // center\n        yWarning = bottomInput + tengahWarning; // center\n\n        ukuranTeksSalah = ukuranTeks;\n        ukuranIkonSalah = Math.floor(ukuranTeks * 1);\n        spasiTeksSalah = Math.floor(ukuranTeks / 2);\n\n        lebarLogoHal2 = Math.floor(lebarHalaman * 0.60);\n        tinggiLogoHal2 = lebarLogoHal2;\n        xLogoHal2 = Math.floor(lebarHalaman * 0.50); // center\n        yLogoHal2 = Math.floor(tinggiHalaman * 0.50) - tinggiLogoHal2;\n\n        ukuranTeksHal2 = ukuranTeks;\n        lebarTeksHal2 = Math.floor(lebarHalaman * 0.90);\n        xTeksHal2 = Math.floor(lebarHalaman * 0.05);\n        yTeksHal2 = yLogoHal2 + tinggiLogoHal2 + Math.floor(ukuranTeksHal2 * 1);\n    }\n\n    return {\n        lebarLayar,\n        tinggiLayar,\n\n        marginX,\n        marginY,\n        spasiX,\n        spasiY,\n\n        lebarHalaman,\n        tinggiHalaman,\n        xHalaman,\n        yHalaman,\n\n        ukuranTombolTutupHalaman,\n\n        ukuranTeks,\n        lebarTeks,\n        xTeks,\n        yTeks,\n\n        lebarPapanKetik,\n        xPapanKetik,\n        yPapanKetik,\n\n        lebarInput,\n        tinggiInput,\n        yInput,\n\n        xInput1,\n        xInput2,\n        xInput3,\n        xInput4,\n\n        lebarInputTeks,\n        tinggiInputTeks,\n        xInputTeks,\n        yInputTeks,\n\n        ukuranTeksInput,\n\n        xWarning,\n        yWarning,\n\n        ukuranIkonSalah,\n        ukuranTeksSalah,\n        spasiTeksSalah,\n\n        lebarLogoHal2,\n        tinggiLogoHal2,\n        xLogoHal2,\n        yLogoHal2,\n\n        ukuranTeksHal2,\n        lebarTeksHal2,\n        xTeksHal2,\n        yTeksHal2,\n    };\n}\n\n\n\n\nfunction fAturTataLetakPotret(lebarLayar, tinggiLayar) {\n    mLog.jejak('mengatur tata letak potret halaman misi-konfirmasi');\n\n    fInisiasi(lebarLayar, tinggiLayar);\n    fAturTema(lebarLayar, tinggiLayar);\n\n    const tl = fHitungUkuran(lebarLayar, tinggiLayar);\n\n    const tlTombolTutupHalaman = fHitungTataLetakTombolTutupHalaman(tl);\n\n    tombolTutupHalaman.aturDimensi(tlTombolTutupHalaman.dimensi.lebar, tlTombolTutupHalaman.dimensi.tinggi);\n    tombolTutupHalaman.aturPosisi(tlTombolTutupHalaman.posisi.x, tlTombolTutupHalaman.posisi.y);\n\n    fBuatHalaman(tl);\n}\n\n\n\n\nfunction fAturTataLetakLanskap(lebarLayar, tinggiLayar) {\n    mLog.jejak('mengatur tata letak lanskap halaman misi-konfirmasi');\n    // TODO\n    throw new Error('belum dimplementasikan');\n}\n\n\n\n\n__ekspor('aturTataLetak', (lebarLayar, tinggiLayar) => {\n    if (lebarLayar >= tinggiLayar) {\n        fAturTataLetakLanskap(lebarLayar, tinggiLayar);\n    } else {\n        fAturTataLetakPotret(lebarLayar, tinggiLayar);\n    }\n});\n\n\n\n\nfunction fBuka(misi) {\n    MISI_TERPILIH = misi;\n    fInput__klir();\n    elWarning.style.display = 'none';\n    fKeHal1();\n}\n\n\n__ekspor('buka', fBuka);\n"}, "beranda": {"halaman/beranda/indeks.css": "\n\n", "halaman/beranda/indeks.html": "\n\n<div id=\"foto_profil\">^_^</div>\n\n<div id=\"level\">1</div>\n\n<div id=\"kredit\">0</div>\n\n<div id=\"banner\">Pemenang turnamen minggu ini</div>\n\n<div id=\"misi\">Misi</div>\n\n<div id=\"market\">Market</div>\n\n<div id=\"inventori\">Inventori</div>\n\n<div id=\"email\">Email</div>\n\n<div id=\"konfig\">Konfig</div>\n", "halaman/beranda/indeks.js": "const log = __impor('modul/0log');\n\n\nlog.info('memuat halaman beranda');\n", "halaman/beranda/tata_letak.js": "const mLog = __impor('modul/0log');\n\nconst mEtalaseFotoProfil = __impor('modul/etalase.foto_profil');\nconst mEtalaseLevel = __impor('modul/etalase.level');\nconst mEtalaseKredit = __impor('modul/etalase.kredit');\nconst mEtalaseBanner = __impor('modul/etalase.banner');\n\nconst mEtalaseMisi = __impor('modul/etalase.misi');\nconst mEtalaseInventori = __impor('modul/etalase.inventori');\nconst mEtalaseMarket = __impor('modul/etalase.market');\nconst mEtalaseEmail = __impor('modul/etalase.email');\nconst mEtalaseKonfig = __impor('modul/etalase.konfig');\n\n\n\n\nconst etalaseFotoProfil = mEtalaseFotoProfil.buat();\nconst etalaseLevel = mEtalaseLevel.buat();\nconst etalaseKredit = mEtalaseKredit.buat();\nconst etalaseBanner = mEtalaseBanner.buat();\n\nconst etalaseMisi = mEtalaseMisi.buat();\nconst etalaseInventori = mEtalaseInventori.buat();\nconst etalaseMarket = mEtalaseMarket.buat();\nconst etalaseEmail = mEtalaseEmail.buat();\nconst etalaseKonfig = mEtalaseKonfig.buat();\n\n\n\n\nfunction fInisiasi(lebarLayar, tinggiLayar) {\n    etalaseFotoProfil.inisiasi(__el.querySelector('#foto_profil'), lebarLayar, tinggiLayar);\n    etalaseLevel.inisiasi(__el.querySelector('#level'), lebarLayar, tinggiLayar);\n    etalaseKredit.inisiasi(__el.querySelector('#kredit'), lebarLayar, tinggiLayar);\n    etalaseBanner.inisiasi(__el.querySelector('#banner'), lebarLayar, tinggiLayar);\n\n    etalaseMisi.inisiasi(__el.querySelector('#misi'), lebarLayar, tinggiLayar);\n    etalaseInventori.inisiasi(__el.querySelector('#inventori'), lebarLayar, tinggiLayar);\n    etalaseMarket.inisiasi(__el.querySelector('#market'), lebarLayar, tinggiLayar);\n    etalaseEmail.inisiasi(__el.querySelector('#email'), lebarLayar, tinggiLayar);\n    etalaseKonfig.inisiasi(__el.querySelector('#konfig'), lebarLayar, tinggiLayar);\n}\n\n\n\nfunction fHitungTataLetakEtalaseFotoProfil(ukuran) {\n    return {\n        dimensi: {\n            lebar: ukuran.ukuranFotoProfil,\n            tinggi: ukuran.ukuranFotoProfil\n        },\n        posisi: {\n            x: ukuran.marginX,\n            y: ukuran.marginY\n        }\n    };\n}\n\nfunction fHitungTataLetakEtalaseLevel(ukuran, tlEtalaseFotoProfil) {\n    return {\n        dimensi: {\n            lebar: ukuran.lebarLayar - (ukuran.ukuranFotoProfil + (ukuran.marginX * 2) + ukuran.spasiX),\n            tinggi: ukuran.ukuranFotoProfil\n        },\n        posisi: {\n            x: tlEtalaseFotoProfil.posisi.x + tlEtalaseFotoProfil.dimensi.lebar + ukuran.spasiX,\n            y: ukuran.marginY\n        }\n    };\n}\n\nfunction fHitungTataLetakEtalaseKredit(ukuran, tlEtalaseFotoProfil) {\n    return {\n        dimensi: {\n            lebar: ukuran.lebarLayar - (ukuran.marginX * 2),\n            tinggi: ukuran.tinggiKredit\n        },\n        posisi: {\n            x: ukuran.marginX,\n            y: (tlEtalaseFotoProfil.posisi.y + tlEtalaseFotoProfil.dimensi.tinggi) + ukuran.spasiY\n        }\n    };\n}\n\nfunction fHitungTataLetakEtalaseBanner(ukuran, tlEtalaseKredit) {\n    return {\n        dimensi: {\n            lebar: ukuran.lebarLayar - (ukuran.marginX * 2),\n            tinggi: ukuran.tinggiBanner\n        },\n        posisi: {\n            x: ukuran.marginX,\n            y: (tlEtalaseKredit.posisi.y + tlEtalaseKredit.dimensi.tinggi) + ukuran.spasiY\n        }\n    };\n}\n\n\n\n\nfunction fHitungTataLetakEtalaseMisi(ukuran, tlEtalaseMarket) {\n    const tinggiEtalase = ukuran.tinggiEtalase;\n    return {\n        dimensi: {\n            lebar: ukuran.lebarEtalase,\n            tinggi: tinggiEtalase\n        },\n        posisi: {\n            x: ukuran.marginX,\n            y: tlEtalaseMarket.posisi.y - tinggiEtalase - ukuran.spasiY\n        }\n    };\n}\n\n\nfunction fHitungTataLetakEtalaseInventori(ukuran, tlEtalaseMisi) {\n    return {\n        dimensi: {\n            lebar: ukuran.lebarEtalase,\n            tinggi: ukuran.tinggiEtalase\n        },\n        posisi: {\n            x: ukuran.lebarLayar - ukuran.lebarEtalase - ukuran.marginX,\n            y: tlEtalaseMisi.posisi.y\n        }\n    };\n}\n\n\nfunction fHitungTataLetakEtalaseMarket(ukuran) {\n    return {\n        dimensi: {\n            lebar: ukuran.lebarEtalase,\n            tinggi: ukuran.tinggiEtalase\n        },\n        posisi: {\n            x: ukuran.marginX,\n            y: ukuran.tinggiLayar - (ukuran.tinggiEtalase + ukuran.marginY)\n        }\n    };\n}\n\nfunction fHitungTataLetakEtalaseKonfig(ukuran) {\n    const lebarEtalase = ukuran.lebarEtalase;\n    const tinggiEtalase = (ukuran.tinggiEtalase / 2) - (ukuran.spasiY / 2);\n    return {\n        dimensi: {\n            lebar: lebarEtalase,\n            tinggi: tinggiEtalase\n        },\n        posisi: {\n            x: ukuran.lebarLayar - lebarEtalase - ukuran.marginX,\n            y: ukuran.tinggiLayar - tinggiEtalase - ukuran.marginY\n        }\n    };\n}\n\nfunction fHitungTataLetakEtalaseEmail(ukuran, tlEtalaseKonfig) {\n    const lebarEtalase = ukuran.lebarEtalase;\n    const tinggiEtalase = tlEtalaseKonfig.dimensi.tinggi;\n    return {\n        dimensi: {\n            lebar: lebarEtalase,\n            tinggi: tinggiEtalase\n        },\n        posisi: {\n            x: ukuran.lebarLayar - (lebarEtalase + ukuran.marginX),\n            y: tlEtalaseKonfig.posisi.y - tinggiEtalase - ukuran.spasiY\n        }\n    };\n}\n\n\n\n\n\n\nfunction fHitungUkuran(lebarLayar, tinggiLayar) {\n    let marginX,\n        marginY,\n        spasiX,\n        spasiY,\n        lebarEtalase,\n        tinggiEtalase,\n        ukuranFotoProfil,\n        tinggiKredit,\n        tinggiBanner;\n\n    if (lebarLayar > tinggiLayar) {\n        // TODO\n        throw new Error('belum dimplementasikan');\n    } else {\n        spasiX = 5;\n        spasiY = 0;\n\n        marginX = 5;\n        marginY = 0;\n\n        ukuranFotoProfil = Math.min(50, Math.floor(Math.min(lebarLayar, tinggiLayar) * 0.20));\n\n        lebarEtalase = Math.floor((lebarLayar - (marginX * 2) - spasiX) / 2);\n\n        tinggiKredit = Math.floor(ukuranFotoProfil * 2.5);\n        tinggiBanner = Math.floor(ukuranFotoProfil * 2);\n        tinggiEtalase = Math.floor(ukuranFotoProfil * 3.25);\n\n        let sisaSpasi = tinggiLayar - (ukuranFotoProfil + tinggiKredit + tinggiBanner + (tinggiEtalase * 2));\n\n        const maksTinggiEtalase = Math.floor((tinggiLayar - (marginY + ukuranFotoProfil + spasiY + tinggiKredit + spasiY + tinggiBanner + spasiY + spasiY + marginY)) / 2);\n\n        if (sisaSpasi > 0) {\n            const tinggiEtalaseBaru = Math.min(maksTinggiEtalase, tinggiEtalase + sisaSpasi);\n            sisaSpasi -= Math.max(0, tinggiEtalaseBaru - tinggiEtalase);\n            tinggiEtalase = tinggiEtalaseBaru;\n        }\n\n        if (sisaSpasi > 0) {\n            marginY = Math.floor(sisaSpasi / 6);\n            spasiY = marginY;\n            tinggiEtalase = Math.floor((tinggiLayar - (marginY + ukuranFotoProfil + spasiY + tinggiKredit + spasiY + tinggiBanner + spasiY + spasiY + marginY)) / 2);\n        }\n\n        /*\n        console.warn({\n            lebarLayar,\n            tinggiLayar,\n            ukuranFotoProfil,\n            lebarEtalase,\n            tinggiKredit,\n            tinggiBanner,\n            tinggiEtalase,\n            maksTinggiEtalase,\n            sisaSpasi,\n            marginY,\n            spasiY,\n        });\n        */\n    }\n\n    return {\n        lebarLayar,\n        tinggiLayar,\n        marginX,\n        marginY,\n        spasiX,\n        spasiY,\n        lebarEtalase,\n        tinggiEtalase,\n        ukuranFotoProfil,\n        tinggiKredit,\n        tinggiBanner,\n    };\n}\n\n\n\n\n\nfunction fAturTataLetakPotret(lebarLayar, tinggiLayar) {\n    mLog.jejak('mengatur tata letak potret halaman beranda');\n\n    fInisiasi(lebarLayar, tinggiLayar);\n\n    const ukuran = fHitungUkuran(lebarLayar, tinggiLayar);\n\n    const tlEtalaseFotoProfil = fHitungTataLetakEtalaseFotoProfil(ukuran);\n    const tlEtalaseLevel = fHitungTataLetakEtalaseLevel(ukuran, tlEtalaseFotoProfil);\n    const tlEtalaseKredit = fHitungTataLetakEtalaseKredit(ukuran, tlEtalaseFotoProfil);\n    const tlEtalaseBanner = fHitungTataLetakEtalaseBanner(ukuran, tlEtalaseKredit);\n\n    const tlEtalaseMarket = fHitungTataLetakEtalaseMarket(ukuran);\n    const tlEtalaseMisi = fHitungTataLetakEtalaseMisi(ukuran, tlEtalaseMarket);\n    const tlEtalaseInventori = fHitungTataLetakEtalaseInventori(ukuran, tlEtalaseMisi);\n    const tlEtalaseKonfig = fHitungTataLetakEtalaseKonfig(ukuran);\n    const tlEtalaseEmail = fHitungTataLetakEtalaseEmail(ukuran, tlEtalaseKonfig);\n\n    etalaseFotoProfil.aturDimensi(tlEtalaseFotoProfil.dimensi.lebar, tlEtalaseFotoProfil.dimensi.tinggi);\n    etalaseFotoProfil.aturPosisi(tlEtalaseFotoProfil.posisi.x, tlEtalaseFotoProfil.posisi.y);\n\n    etalaseLevel.aturDimensi(tlEtalaseLevel.dimensi.lebar, tlEtalaseLevel.dimensi.tinggi);\n    etalaseLevel.aturPosisi(tlEtalaseLevel.posisi.x, tlEtalaseLevel.posisi.y);\n\n    etalaseKredit.aturDimensi(tlEtalaseKredit.dimensi.lebar, tlEtalaseKredit.dimensi.tinggi);\n    etalaseKredit.aturPosisi(tlEtalaseKredit.posisi.x, tlEtalaseKredit.posisi.y);\n\n    etalaseBanner.aturDimensi(tlEtalaseBanner.dimensi.lebar, tlEtalaseBanner.dimensi.tinggi);\n    etalaseBanner.aturPosisi(tlEtalaseBanner.posisi.x, tlEtalaseBanner.posisi.y);\n\n    etalaseMisi.aturDimensi(tlEtalaseMisi.dimensi.lebar, tlEtalaseMisi.dimensi.tinggi);\n    etalaseMisi.aturPosisi(tlEtalaseMisi.posisi.x, tlEtalaseMisi.posisi.y);\n\n    etalaseInventori.aturDimensi(tlEtalaseInventori.dimensi.lebar, tlEtalaseInventori.dimensi.tinggi);\n    etalaseInventori.aturPosisi(tlEtalaseInventori.posisi.x, tlEtalaseInventori.posisi.y);\n\n    etalaseMarket.aturDimensi(tlEtalaseMarket.dimensi.lebar, tlEtalaseMarket.dimensi.tinggi);\n    etalaseMarket.aturPosisi(tlEtalaseMarket.posisi.x, tlEtalaseMarket.posisi.y);\n\n    etalaseKonfig.aturDimensi(tlEtalaseKonfig.dimensi.lebar, tlEtalaseKonfig.dimensi.tinggi);\n    etalaseKonfig.aturPosisi(tlEtalaseKonfig.posisi.x, tlEtalaseKonfig.posisi.y);\n\n    etalaseEmail.aturDimensi(tlEtalaseEmail.dimensi.lebar, tlEtalaseEmail.dimensi.tinggi);\n    etalaseEmail.aturPosisi(tlEtalaseEmail.posisi.x, tlEtalaseEmail.posisi.y);\n}\n\n\n\nfunction fAturTataLetakLanskap(lebarLayar, tinggiLayar) {\n    mLog.jejak('mengatur tata letak lanskap halaman beranda');\n    // TODO\n    throw new Error('belum dimplementasikan');\n}\n\n\n\n\n__ekspor('aturTataLetak', (lebarLayar, tinggiLayar) => {\n    if (lebarLayar >= tinggiLayar) {\n        fAturTataLetakLanskap(lebarLayar, tinggiLayar);\n    } else {\n        fAturTataLetakPotret(lebarLayar, tinggiLayar);\n    }\n});\n"}, "misi": {"halaman/misi/indeks.css": "{{el}} {\n\n}\n", "halaman/misi/indeks.html": "\n<div id=\"tutup_halaman\"></div>\n", "halaman/misi/indeks.js": "const log = __impor('modul/0log');\n\n\nlog.info('memuat halaman misi');\n", "halaman/misi/tata_letak.js": "const mLog = __impor('modul/0log');\n\nconst mTombolTutupHalaman = __impor('modul/0tombol.tutup_halaman');\n\n\n\nconst tombolTutupHalaman = mTombolTutupHalaman.buat();\n\n\n\n\nfunction fAturTrei(lebarLayar, tinggiLayar) {\n    const gambarTreiAtas = __impor('aset/gambar/trei-atas-1.png')