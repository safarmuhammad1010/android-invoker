{"halaman": {"item": {"halaman/item/indeks.css": "{{el}} {\n\n}\n", "halaman/item/indeks.html": "\n<div id=\"tutup_halaman\"></div>\n", "halaman/item/indeks.js": "const log = __impor('modul/0log');\n\n\nlog.info('memuat halaman item');\n", "halaman/item/tata_letak.js": "const mLog = __impor('modul/0log');\n\nconst mTombolTutupHalaman = __impor('modul/0tombol.tutup_halaman');\n\n\n\nconst mItemDipakai = __impor('modul/item_dipakai');\n\n\n\n\nconst tombolTutupHalaman = mTombolTutupHalaman.buat();\n\n\n\nfunction fAturTrei(lebarLayar, tinggiLayar) {\n    const gambarTreiAtas = __impor('aset/gambar/trei-atas-2.png');\n    const gambarTreiTengah1 = __impor('aset/gambar/trei-tengah-1.png');\n    const gambarTreiTengah2 = __impor('aset/gambar/trei-tengah-2.png');\n    const gambarTreiBawah = __impor('aset/gambar/trei-bawah-1.png');\n\n    const elTrei = document.createElement('div');\n    elTrei.style.position = 'absolute';\n    elTrei.style.top = '0';\n    elTrei.style.left = '0';\n    elTrei.style.width = '100%';\n    elTrei.style.height = '100%';\n    elTrei.style.margin = '0';\n    elTrei.style.padding = '0';\n\n    const elTreiAtas = document.createElement('img');\n    elTreiAtas.src = `data:image/png;base64,${gambarTreiAtas}`;\n    elTreiAtas.style.display = 'block';\n    elTreiAtas.style.width = '100%';\n    elTreiAtas.style.height = '15%';\n    elTreiAtas.style.margin = '0';\n    elTrei.appendChild(elTreiAtas);\n\n    const elTreiTengah1 = document.createElement('img');\n    elTreiTengah1.src = `data:image/png;base64,${gambarTreiTengah1}`;\n    elTreiTengah1.style.display = 'block';\n    elTreiTengah1.style.width = '100%';\n    elTreiTengah1.style.height = '35%';\n    elTreiTengah1.style.margin = '0';\n    elTrei.appendChild(elTreiTengah1);\n\n    const elTreiTengah2 = document.createElement('img');\n    elTreiTengah2.src = `data:image/png;base64,${gambarTreiTengah2}`;\n    elTreiTengah2.style.display = 'block';\n    elTreiTengah2.style.width = '100%';\n    elTreiTengah2.style.height = '35%';\n    elTreiTengah2.style.margin = '0';\n    elTrei.appendChild(elTreiTengah2);\n\n    const elTreiBawah = document.createElement('img');\n    elTreiBawah.src = `data:image/png;base64,${gambarTreiBawah}`;\n    elTreiBawah.style.display = 'block';\n    elTreiBawah.style.width = '100%';\n    elTreiBawah.style.height = '15%';\n    elTreiBawah.style.margin = '0';\n    elTrei.appendChild(elTreiBawah);\n\n    __el.prepend(elTrei);\n}\n\n\nfunction fAturTema(lebarLayar, tinggiLayar) {\n    __el.style.position = 'relative';\n    fAturTrei(lebarLayar, tinggiLayar);\n}\n\n\n\n\nfunction fInisiasi(lebarLayar, tinggiLayar) {\n    tombolTutupHalaman.inisiasi(__el.querySelector('#tutup_halaman'), lebarLayar, tinggiLayar);\n}\n\n\n\nfunction fHitungTataLetakTombolTutupHalaman(ukuran) {\n    return {\n        dimensi: {\n            lebar: ukuran.ukuranTombolTutupHalaman,\n            tinggi: ukuran.ukuranTombolTutupHalaman\n        },\n        posisi: {\n            x: ukuran.lebarLayar * 0.88,\n            y: ukuran.tinggiLayar * 0.02\n        }\n    };\n}\n\n\n\nlet elHalaman;\nlet elTombolPakai;\nlet TL;\nlet ITEM_SEKARANG;\n\n\n\nfunction fBuatHalaman(tl) {\n    TL = tl;\n\n    const elTrei = document.createElement('img');\n    elTrei.style.position = 'absolute';\n    elTrei.style.width = tl.lebarHalaman + 'px';\n    elTrei.style.height = tl.tinggiHalaman + 'px';\n    elTrei.style.left = tl.xHalaman + 'px';\n    elTrei.style.top = tl.yHalaman + 'px';\n    elTrei.src = __tema.gambar('latar-item-info');\n    __el.appendChild(elTrei);\n\n    elHalaman = document.createElement('div');\n    elHalaman.style.position = 'absolute';\n    elHalaman.style.width = tl.lebarHalaman + 'px';\n    elHalaman.style.height = tl.tinggiHalaman + 'px';\n    elHalaman.style.left = tl.xHalaman + 'px';\n    elHalaman.style.top = tl.yHalaman + 'px';\n    __el.appendChild(elHalaman);\n\n    elTombolPakai = document.createElement('img');\n    elTombolPakai.style.position = 'absolute';\n    elTombolPakai.style.transform = 'translate(-50%, 0)';\n    elTombolPakai.style.width = TL.lebarTombolPakai + 'px';\n    elTombolPakai.style.height = TL.tinggiTombolPakai + 'px';\n    elTombolPakai.style.left = TL.xTombolPakai + 'px';\n    elTombolPakai.style.top = TL.yTombolPakai + 'px';\n    elTombolPakai.src = __tema.gambar('tombol_pakai-1');\n    __el.appendChild(elTombolPakai);\n\n    elTombolPakai.addEventListener('click', () => {\n        elTombolPakai.src = __tema.gambar('tombol_pakai-2');\n        setTimeout(() => {\n            elTombolPakai.src = __tema.gambar('tombol_pakai-1');\n            __pakai_item(ITEM_SEKARANG.has);\n            mItemDipakai.tampilkan(ITEM_SEKARANG);\n        }, 200);\n    });\n}\n\n\n\nfunction fHitungUkuran(lebarLayar, tinggiLayar) {\n    let marginX,\n        marginY,\n        spasiX,\n        spasiY,\n\n        lebarHalaman,\n        tinggiHalaman,\n        xHalaman,\n        yHalaman,\n\n        ukuranTombolTutupHalaman,\n\n        lebarLogo,\n        tinggiLogo,\n        xLogo,\n        yLogo,\n\n        lebarBoks,\n        tinggiBoks,\n        xBoks,\n        yBoks,\n\n        ukuranTeks,\n\n        lebarTombolPakai,\n        tinggiTombolPakai,\n        xTombolPakai,\n        yTombolPakai;\n\n    if (lebarLayar > tinggiLayar) {\n        // TODO\n        throw new Error('belum dimplementasikan');\n    } else {\n        marginX = 5;\n        marginY = 20;\n        spasiX = 5;\n        spasiY = 10;\n\n        ukuranTombolTutupHalaman = Math.min(30, Math.round(Math.min(lebarLayar, tinggiLayar) * 0.15));\n\n        lebarHalaman = Math.floor(lebarLayar * 0.895);\n        tinggiHalaman = Math.floor(tinggiLayar * 0.895);\n        xHalaman = Math.floor(lebarLayar * 0.055);\n        yHalaman = Math.floor(tinggiLayar * 0.080);\n\n        lebarLogo = Math.floor(lebarHalaman * 0.956);\n        tinggiLogo = Math.floor(tinggiHalaman * 0.4780);\n        xLogo = Math.floor(lebarHalaman * 0.022);\n        yLogo = Math.floor(tinggiHalaman * 0.012);\n\n        lebarBoks = Math.floor(lebarHalaman * 0.950);\n        tinggiBoks = Math.floor(tinggiHalaman * 0.408);\n        xBoks = xLogo;\n        yBoks = yLogo + tinggiLogo + Math.floor(tinggiHalaman * 0.016);\n\n        ukuranTeks = Math.floor(tinggiHalaman * 0.06);\n\n        lebarTombolPakai = Math.floor(lebarHalaman * 0.72);\n        tinggiTombolPakai = Math.floor(tinggiHalaman * 0.08);\n        xTombolPakai = Math.floor(lebarLayar * 0.50);\n        yTombolPakai = Math.floor(tinggiLayar * 0.915);\n    }\n\n    return {\n        lebarLayar,\n        tinggiLayar,\n\n        marginX,\n        marginY,\n        spasiX,\n        spasiY,\n\n        lebarHalaman,\n        tinggiHalaman,\n        xHalaman,\n        yHalaman,\n\n        ukuranTombolTutupHalaman,\n\n        lebarLogo,\n        tinggiLogo,\n        xLogo,\n        yLogo,\n\n        lebarBoks,\n        tinggiBoks,\n        xBoks,\n        yBoks,\n\n        ukuranTeks,\n\n        lebarTombolPakai,\n        tinggiTombolPakai,\n        xTombolPakai,\n        yTombolPakai,\n    };\n}\n\n\n\nfunction fAturTataLetakPotret(lebarLayar, tinggiLayar) {\n    mLog.jejak('mengatur tata letak potret halaman item');\n\n    fInisiasi(lebarLayar, tinggiLayar);\n    fAturTema(lebarLayar, tinggiLayar);\n\n    const tl = fHitungUkuran(lebarLayar, tinggiLayar);\n\n    const tlTombolTutupHalaman = fHitungTataLetakTombolTutupHalaman(tl);\n\n    tombolTutupHalaman.aturDimensi(tlTombolTutupHalaman.dimensi.lebar, tlTombolTutupHalaman.dimensi.tinggi);\n    tombolTutupHalaman.aturPosisi(tlTombolTutupHalaman.posisi.x, tlTombolTutupHalaman.posisi.y);\n\n    fBuatHalaman(tl);\n}\n\n\n\n\nfunction fAturTataLetakLanskap(lebarLayar, tinggiLayar) {\n    mLog.jejak('mengatur tata letak lanskap halaman item');\n    // TODO\n    throw new Error('belum dimplementasikan');\n}\n\n\n\n\n__ekspor('aturTataLetak', (lebarLayar, tinggiLayar) => {\n    if (lebarLayar >= tinggiLayar) {\n        fAturTataLetakLanskap(lebarLayar, tinggiLayar);\n    } else {\n        fAturTataLetakPotret(lebarLayar, tinggiLayar);\n    }\n});\n\n\n\nfunction fBuka(item) {\n    while (elHalaman.firstChild)\n        elHalaman.removeChild(elHalaman.firstChild);\n\n    const elLogo = document.createElement('img');\n    elLogo.style.position = 'absolute';\n    elLogo.style.width = TL.lebarLogo + 'px';\n    elLogo.style.height = TL.tinggiLogo + 'px';\n    elLogo.style.left = TL.xLogo + 'px';\n    elLogo.style.top = TL.yLogo + 'px';\n    if (item.logo.startsWith('http://') || item.logo.startsWith('https://')) {\n        elLogo.src = item.logo;\n    } else {\n        elLogo.src = __tema.gambar(item.logo);\n    }\n    elHalaman.appendChild(elLogo);\n\n    const elBoks = document.createElement('div');\n    elBoks.style.position = 'absolute';\n    elBoks.style.width = TL.lebarBoks + 'px';\n    elBoks.style.height = TL.tinggiBoks + 'px';\n    elBoks.style.left = TL.xBoks + 'px';\n    elBoks.style.top = TL.yBoks + 'px';\n    elBoks.style.paddingTop = 2 + 'px';\n    elBoks.style.paddingBottom = 2 + 'px';\n    elBoks.style.paddingLeft = 2 + 'px';\n    elBoks.style.paddingRight = 2 + 'px';\n    elBoks.style.overflowY = 'auto';\n    elBoks.style.color = __tema.warna('teks');\n    elHalaman.appendChild(elBoks);\n\n    elBoks.innerHTML = item.keterangan;\n\n    if (item.tipe == 'konsumtif') {\n        elTombolPakai.style.display = 'block';\n    } else {\n        elTombolPakai.style.display = 'none';\n    }\n\n    ITEM_SEKARANG = item;\n}\n\n\n\n__ekspor('buka', fBuka);\n"}, "baca_email": {"halaman/baca_email/indeks.css": "{{el}} {\n\n}\n", "halaman/baca_email/indeks.html": "\n<div id=\"tutup_halaman\"></div>\n", "halaman/baca_email/indeks.js": "const log = __impor('modul/0log');\n\n\nlog.info('memuat halaman baca_email');\n", "halaman/baca_email/tata_letak.js": "const mLog = __impor('modul/0log');\n\nconst mTombolTutupHalaman = __impor('modul/0tombol.tutup_halaman');\n\nconst mSkroller = __impor('modul/0skroller');\n\n\nconst tombolTutupHalaman = mTombolTutupHalaman.buat();\n\n\n\nlet elSubjek;\nlet elPesan;\n\n\n\nfunction fAturTrei(lebarLayar, tinggiLayar) {\n    const gambarTreiAtas = __impor('aset/gambar/trei-atas-2.png');\n    const gambarTreiTengah1 = __impor('aset/gambar/trei-tengah-1.png');\n    const gambarTreiTengah2 = __impor('aset/gambar/trei-tengah-2.png');\n    const gambarTreiBawah = __impor('aset/gambar/trei-bawah-2.png');\n\n    const elTrei = document.createElement('div');\n    elTrei.style.position = 'absolute';\n    elTrei.style.top = '0';\n    elTrei.style.left = '0';\n    elTrei.style.width = '100%';\n    elTrei.style.height = '100%';\n    elTrei.style.margin = '0';\n    elTrei.style.padding = '0';\n\n    const elTreiAtas = document.createElement('img');\n    elTreiAtas.src = `data:image/png;base64,${gambarTreiAtas}`;\n    elTreiAtas.style.display = 'block';\n    elTreiAtas.style.width = '100%';\n    elTreiAtas.style.height = '15%';\n    elTreiAtas.style.margin = '0';\n    elTrei.appendChild(elTreiAtas);\n\n    const elTreiTengah1 = document.createElement('img');\n    elTreiTengah1.src = `data:image/png;base64,${gambarTreiTengah1}`;\n    elTreiTengah1.style.display = 'block';\n    elTreiTengah1.style.width = '100%';\n    elTreiTengah1.style.height = '35%';\n    elTreiTengah1.style.margin = '0';\n    elTrei.appendChild(elTreiTengah1);\n\n    const elTreiTengah2 = document.createElement('img');\n    elTreiTengah2.src = `data:image/png;base64,${gambarTreiTengah2}`;\n    elTreiTengah2.style.display = 'block';\n    elTreiTengah2.style.width = '100%';\n    elTreiTengah2.style.height = '35%';\n    elTreiTengah2.style.margin = '0';\n    elTrei.appendChild(elTreiTengah2);\n\n    const elTreiBawah = document.createElement('img');\n    elTreiBawah.src = `data:image/png;base64,${gambarTreiBawah}`;\n    elTreiBawah.style.display = 'block';\n    elTreiBawah.style.width = '100%';\n    elTreiBawah.style.height = '15%';\n    elTreiBawah.style.margin = '0';\n    elTrei.appendChild(elTreiBawah);\n\n    __el.prepend(elTrei);\n}\n\n\nfunction fAturTema(lebarLayar, tinggiLayar) {\n    __el.style.position = 'relative';\n    fAturTrei(lebarLayar, tinggiLayar);\n}\n\n\n\n\nfunction fInisiasi(lebarLayar, tinggiLayar) {\n    tombolTutupHalaman.inisiasi(__el.querySelector('#tutup_halaman'), lebarLayar, tinggiLayar);\n}\n\n\n\nfunction fHitungTataLetakTombolTutupHalaman(ukuran) {\n    return {\n        dimensi: {\n            lebar: ukuran.ukuranTombolTutupHalaman,\n            tinggi: ukuran.ukuranTombolTutupHalaman\n        },\n        posisi: {\n            x: ukuran.lebarLayar * 0.88,\n            y: ukuran.tinggiLayar * 0.02\n        }\n    };\n}\n\n\n\nfunction fHitungUkuran(lebarLayar, tinggiLayar) {\n    let marginX,\n        marginY,\n        spasiX,\n        spasiY,\n        ukuranTombolTutupHalaman;\n\n    if (lebarLayar > tinggiLayar) {\n        // TODO\n        throw new Error('belum dimplementasikan');\n    } else {\n        marginX = 5;\n        marginY = 20;\n        spasiX = 5;\n        spasiY = 10;\n\n        ukuranTombolTutupHalaman = Math.min(30, Math.round(Math.min(lebarLayar, tinggiLayar) * 0.15));\n    }\n\n    return {\n        lebarLayar,\n        tinggiLayar,\n        marginX,\n        marginY,\n        spasiX,\n        spasiY,\n        ukuranTombolTutupHalaman\n    };\n}\n\n\n\nfunction fBuatHalaman(lebarLayar, tinggiLayar) {\n    const lebarHalaman = Math.floor(lebarLayar * 0.895);\n    const tinggiHalaman = Math.floor(tinggiLayar * 0.895);\n    const xHalaman = Math.floor(lebarLayar * 0.055);\n    const yHalaman = Math.floor(tinggiLayar * 0.080);\n\n    const ukuranSubjek = Math.floor(lebarHalaman * 0.04);\n    const ukuranPesan = Math.floor(lebarHalaman * 0.045);\n\n    const paddingX = Math.floor(ukuranSubjek / 2);\n    const paddingY = Math.floor(ukuranSubjek / 2);\n\n    const elHalaman = document.createElement('div');\n    elHalaman.style.position = 'absolute';\n    elHalaman.style.width = lebarHalaman + 'px';\n    elHalaman.style.height = tinggiHalaman + 'px';\n    elHalaman.style.left = xHalaman + 'px';\n    elHalaman.style.top = yHalaman + 'px';\n    __el.appendChild(elHalaman);\n\n    const skroller = mSkroller.buat(lebarHalaman, tinggiHalaman);\n    elHalaman.appendChild(skroller.kontener());\n\n    const elKonten = skroller.konten();\n\n    elSubjek = document.createElement('div');\n    elSubjek.style.paddingLeft = paddingX + 'px';\n    elSubjek.style.paddingRight = paddingX + 'px';\n    elSubjek.style.paddingTop = paddingY + 'px';\n    elSubjek.style.fontFamily = __tema.teks('varianHuruf');\n    elSubjek.style.fontSize = ukuranSubjek + 'px';\n    elSubjek.style.color = __tema.warna('primer');\n    elKonten.appendChild(elSubjek);\n\n    elPesan = document.createElement('div');\n    elPesan.style.paddingLeft = paddingX + 'px';\n    elPesan.style.paddingRight = paddingX + 'px';\n    elPesan.style.fontFamily = __tema.teks('varianHuruf');\n    elPesan.style.fontSize = ukuranPesan + 'px';\n    elPesan.style.color = __tema.warna('teks');\n    elKonten.appendChild(elPesan);\n}\n\n\n\nfunction fAturTataLetakPotret(lebarLayar, tinggiLayar) {\n    mLog.jejak('mengatur tata letak potret halaman baca_email');\n\n    fInisiasi(lebarLayar, tinggiLayar);\n    fAturTema(lebarLayar, tinggiLayar);\n\n    const ukuran = fHitungUkuran(lebarLayar, tinggiLayar);\n\n    const tlTombolTutupHalaman = fHitungTataLetakTombolTutupHalaman(ukuran);\n\n    tombolTutupHalaman.aturDimensi(tlTombolTutupHalaman.dimensi.lebar, tlTombolTutupHalaman.dimensi.tinggi);\n    tombolTutupHalaman.aturPosisi(tlTombolTutupHalaman.posisi.x, tlTombolTutupHalaman.posisi.y);\n\n    fBuatHalaman(lebarLayar, tinggiLayar)\n}\n\n\n\n\nfunction fAturTataLetakLanskap(lebarLayar, tinggiLayar) {\n    mLog.jejak('mengatur tata letak lanskap halaman baca_email');\n    // TODO\n    throw new Error('belum dimplementasikan');\n}\n\n\n\n\nfunction fBuka(email) {\n    let teksSubjek = '';\n    let teksPesan = '';\n\n    const tgl = __format_tanggal(email.tanggal);\n    const border = '------------------------------------------';\n\n    //teksSubjek += border;\n    //teksSubjek += '<br/>';\n    teksSubjek += 'Subjek: ' + email.subjek;\n    teksSubjek += '<br/>';\n    teksSubjek += 'Tanggal: ' + tgl;\n    teksSubjek += '<br/>';\n    teksSubjek += border;\n\n    teksPesan += email.pesan;\n\n    elSubjek.innerHTML = teksSubjek;\n    elPesan.innerHTML = teksPesan;\n\n    __baca_email(email.has);\n}\n\n\n__ekspor('buka', fBuka);\n\n\n\n\n__ekspor('aturTataLetak', (lebarLayar, tinggiLayar) => {\n    if (lebarLayar >= tinggiLayar) {\n        fAturTataLetakLanskap(lebarLayar, tinggiLayar);\n    } else {\n        fAturTataLetakPotret(lebarLayar, tinggiLayar);\n    }\n});\n"}, "market": {"halaman/market/indeks.css": "{{el}} {\n\n}\n", "halaman/market/indeks.html": "\n<div id=\"tutup_halaman\"></div>\n", "halaman/market/indeks.js": "const log = __impor('modul/0log');\n\n\nlog.info('memuat halaman market');\n", "halaman/market/tata_letak.js": "const mLog = __impor('modul/0log');\n\nconst mTombolTutupHalaman = __impor('modul/0tombol.tutup_halaman');\n\n\n\n\nconst tombolTutupHalaman = mTombolTutupHalaman.buat();\n\n\n\n\nfunction fAturTrei(lebarLayar, tinggiLayar) {\n    const gambarTreiAtas = __impor('aset/gambar/trei-atas-1.png');\n    const gambarTreiTengah1 = __impor('aset/gambar/trei-tengah-1.png');\n    const gambarTreiTengah2 = __impor('aset/gambar/trei-tengah-2.png');\n    const gambarTreiBawah = __impor('aset/gambar/trei-bawah-1.png');\n\n    const elTrei = document.createElement('div');\n    elTrei.style.position = 'absolute';\n    elTrei.style.top = '0';\n    elTrei.style.left = '0';\n    elTrei.style.width = '100%';\n    elTrei.style.height = '100%';\n    elTrei.style.margin = '0';\n    elTrei.style.padding = '0';\n\n    const elTreiAtas = document.createElement('img');\n    elTreiAtas.src = `data:image/png;base64,${gambarTreiAtas}`;\n    elTreiAtas.style.display = 'block';\n    elTreiAtas.style.width = '100%';