date and time\n  const now = new Date();\n\n  // 2. Create a date object for the start of the next day (midnight)\n  const nextDay = new Date(now);\n  nextDay.setDate(now.getDate() + 1); // Increment the day\n  nextDay.setHours(0, 0, 0, 0); // Set time to midnight (00:00:00.000)\n\n  // 3. Calculate the difference in milliseconds\n  const diffInMilliseconds = nextDay.getTime() - now.getTime(); //\n\n  // 4. Convert the milliseconds difference to hours\n  // There are 1000 ms per second, 60 seconds per minute.\n  const minutes = diffInMilliseconds / (1000 * 60);\n\n  // Return the number of minutes (can be a floating-point number)\n  return Math.ceil(minutes);\n}\n\n\n\n\nfunction getDaysUntilNextMonday() {\n    const today = new Date().getDay(); // 0 (Sun) to 6 (Sat)\n    // If today is Monday (1), days until next Monday is 7.\n    // Otherwise, it's 1 (Mon) - today + 7, modulo 7.\n    const daysToNextMonday = today === 1 ? 7 : (8 - today) % 7 || 7;\n\n    return daysToNextMonday;\n}\n\n\n\n\nfunction getDaysUntilNextMonth() {\n  const today = new Date();\n  const year = today.getFullYear();\n  const month = today.getMonth(); // 0-indexed (Jan=0)\n\n  // Get the last day of the current month\n  // (Passing month + 1 with day 0 gives the last day of the current month)\n  const lastDay = new Date(year, month + 1, 0).getDate();\n\n  // Subtract current day from total days in month\n  return lastDay - today.getDate() + 1;\n}\n\n\nfunction fHitungMingguDari(a, b) {\n  // A day in UTC always lasts 24 hours (unlike in other time formats)\n  const oneDayInMs = 1000 * 60 * 60 * 24;\n\n  // Convert the start date string to a Date object\n  const startDate = new Date(a);\n  const currentDate = new Date(b);\n\n  // Get UTC timestamps for both dates, set to midnight\n  const startUTC = Date.UTC(startDate.getFullYear(), startDate.getMonth(), startDate.getDate());\n  const currentUTC = Date.UTC(currentDate.getFullYear(), currentDate.getMonth(), currentDate.getDate());\n\n  // Calculate the difference in milliseconds\n  const differenceMs = Math.abs(currentUTC - startUTC);\n\n  // Convert the difference back to days\n  return Math.floor(differenceMs / oneDayInMs);\n}\n\n\n\n\nfunction fCekLotreHarian() {\n    let a = __data.ambil('lotre_1H-ikut');\n    let b = __tanggal();\n    if (!a) return false;\n    a = new Date(a);\n    b = new Date(b);\n    return a.getFullYear() === b.getFullYear() &&\n         a.getMonth() === b.getMonth() &&\n         a.getDate() === b.getDate();\n}\n\n\nfunction fCekLotreMingguan() {\n    const tglIkut = __data.ambil('lotre_7H-ikut');\n    if (!tglIkut) return false;\n\n    const tglAwal = __data.ambil('lotre_7H-awal');\n    if (!tglAwal) throw Error('tglAwal == undefined');\n\n    const n1 = fHitungMingguDari(tglAwal, new Date());\n    const x1 = Math.floor(n1 / 7);\n\n    const n2 = fHitungMingguDari(tglAwal, tglIkut);\n    const x2 = Math.floor(n2 / 7);\n\n    return x1 === x2;\n}\n\n\nfunction fCekLotreBulanan() {\n    const x1 = __data.ambil('lotre_1B-ikut');\n    if (!x1) return false;\n\n    const d1 = new Date(x1);\n    const b1 = d1.getMonth();\n    const t1 = d1.getFullYear();\n\n    const d2 = new Date();\n    const b2 = d2.getMonth();\n    const t2 = d2.getFullYear();\n\n    return (b1 === b2) && (t1 == t2);\n}\n\n\n\nfunction fBuatTimerLotreHarian() {\n    const jam = hoursToNextDay();\n    if (jam > 0) {\n        return jam + ' jam lagi';\n    } else {\n        const menit = minutesToNextDay();\n        return menit + ' menit lagi';\n    }\n}\n\n\n\nfunction fSinkronkanTimerLotreHarian(elTimer, elTombol) {\n    elTimer.innerHTML = fBuatTimerLotreHarian();\n\n    elTombol.src = fCekLotreHarian()\n        ? __tema.gambar('tombol_lotre-diikuti')\n        : __tema.gambar('tombol_lotre-ikut');\n\n    setTimeout(() => {\n        fSinkronkanTimerLotreHarian(elTimer, elTombol);\n    }, 60 * 1000);\n}\n\n\nfunction fBuatTimerLotreMingguan() {\n    const hari = getDaysUntilNextMonday();\n    if (hari > 0) {\n        return hari + ' hari lagi';\n    } else {\n        return hoursToNextDay();\n    }\n}\n\n\n\nfunction fSinkronkanTimerLotreMingguan(elTimer, elTombol) {\n    elTimer.innerHTML = fBuatTimerLotreMingguan();\n\n    if (parseInt(__data.ambil('xp') / 100) >= 30)\n        elTombol.src = fCekLotreMingguan()\n            ? __tema.gambar('tombol_lotre-diikuti')\n            : __tema.gambar('tombol_lotre-ikut');\n\n    setTimeout(() => {\n        fSinkronkanTimerLotreMingguan(elTimer, elTombol);\n    }, 60 * 1000);\n}\n\n\nfunction fBuatTimerLotreBulanan() {\n    const hari = getDaysUntilNextMonth();\n    if (hari > 0) {\n        return hari + ' hari lagi';\n    } else {\n        return hoursToNextDay();\n    }\n}\n\n\n\nfunction fSinkronkanTimerLotreBulanan(elTimer, elTombol) {\n    elTimer.innerHTML = fBuatTimerLotreBulanan();\n\n    if (parseInt(__data.ambil('xp') / 100) >= 60)\n        elTombol.src = fCekLotreBulanan()\n            ? __tema.gambar('tombol_lotre-diikuti')\n            : __tema.gambar('tombol_lotre-ikut');\n\n    setTimeout(() => {\n        fSinkronkanTimerLotreBulanan(elTimer, elTombol);\n    }, 60 * 1000);\n}\n\n\n\n\nfunction fAturTrei(lebarLayar, tinggiLayar) {\n    const gambarTreiAtas = __impor('aset/gambar/trei-atas-1.png');\n    const gambarTreiTengah1 = __impor('aset/gambar/trei-tengah-1.png');\n    const gambarTreiTengah2 = __impor('aset/gambar/trei-tengah-2.png');\n    const gambarTreiBawah = __impor('aset/gambar/trei-bawah-2.png');\n\n    const elTrei = document.createElement('div');\n    elTrei.style.position = 'absolute';\n    elTrei.style.top = '0';\n    elTrei.style.left = '0';\n    elTrei.style.width = '100%';\n    elTrei.style.height = '100%';\n    elTrei.style.margin = '0';\n    elTrei.style.padding = '0';\n\n    const elTreiAtas = document.createElement('img');\n    elTreiAtas.src = `data:image/png;base64,${gambarTreiAtas}`;\n    elTreiAtas.style.display = 'block';\n    elTreiAtas.style.width = '100%';\n    elTreiAtas.style.height 