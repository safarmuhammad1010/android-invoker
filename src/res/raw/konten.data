\n    elTeks.style.width = tl.lebarTeks + 'px';\n    elTeks.style.height = 'auto';\n    elTeks.style.left = tl.xTeks + 'px';\n    elTeks.style.top = tl.yTeks + 'px';\n    elTeks.style.fontSize = tl.ukuranTeks + 'px';\n    elTeks.style.fontFamily = __tema.teks('varianHuruf');\n    elTeks.style.color = __tema.warna('primer');\n    elTeks.innerHTML = 'Aktifkan notifikasi ?';\n    elHalaman.appendChild(elTeks);\n}\n\n\n\nfunction fBuatTombol(elHalaman, tl) {\n    let statusNyala = (__data.ambil('konfig.notifikasi') == 'ya');\n\n    const elTombolYes = document.createElement('img');\n    elTombolYes.style.position = 'absolute';\n    elTombolYes.style.width = tl.lebarTombol + 'px';\n    elTombolYes.style.height = tl.tinggiTombol + 'px';\n    elTombolYes.style.right = tl.xTombolYes + 'px';\n    elTombolYes.style.bottom = tl.yTombolYes + 'px';\n    elTombolYes.src = statusNyala ? __tema.gambar('tombol-yes-3') : __tema.gambar('tombol-yes-1');\n    elHalaman.appendChild(elTombolYes);\n\n    const elTombolNo = document.createElement('img');\n    elTombolNo.style.position = 'absolute';\n    elTombolNo.style.width = tl.lebarTombol + 'px';\n    elTombolNo.style.height = tl.tinggiTombol + 'px';\n    elTombolNo.style.left = tl.xTombolNo + 'px';\n    elTombolNo.style.bottom = tl.yTombolNo + 'px';\n    elTombolNo.src = statusNyala ? __tema.gambar('tombol-no-1') : __tema.gambar('tombol-no-3');\n    elHalaman.appendChild(elTombolNo);\n\n    elTombolYes.addEventListener('click', () => {\n        if (statusNyala) return;\n        statusNyala = true;\n        elTombolYes.src = __tema.gambar('tombol-yes-2');\n        setTimeout(() => {\n            elTombolNo.src = __tema.gambar('tombol-no-1');\n            elTombolYes.src = __tema.gambar('tombol-yes-3');\n            __data.simpan('konfig.notifikasi', 'ya');\n        }, 200);\n    });\n\n    elTombolNo.addEventListener('click', () => {\n        if (! statusNyala) return;\n        statusNyala = false;\n        elTombolNo.src = __tema.gambar('tombol-no-2');\n        setTimeout(() => {\n            elTombolYes.src = __tema.gambar('tombol-yes-1');\n            elTombolNo.src = __tema.gambar('tombol-no-3');\n            __data.simpan('konfig.notifikasi', 'no');\n        }, 200);\n    });\n}\n\n\n\nfunction fBuatHalaman(tl) {\n    const elHalaman = document.createElement('div');\n    elHalaman.style.position = 'absolute';\n    elHalaman.style.width = tl.lebarHalaman + 'px';\n    elHalaman.style.height = tl.tinggiHalaman + 'px';\n    elHalaman.style.left = tl.xHalaman + 'px';\n    elHalaman.style.top = tl.yHalaman + 'px';\n    __el.appendChild(elHalaman);\n\n    fBuatTeks(elHalaman, tl);\n    fBuatTombol(elHalaman, tl);\n}\n\n\n\nfunction fHitungUkuran(lebarLayar, tinggiLayar) {\n    let marginX,\n        marginY,\n        spasiX,\n        spasiY,\n\n        lebarHalaman,\n        tinggiHalaman,\n        xHalaman,\n        yHalaman,\n\n        ukuranTombolTutupHalaman,\n\n        ukuranTeks,\n        lebarTeks,\n        xTeks,\n        yTeks,\n\n        lebarTombol,\n        tinggiTombol,\n\n        xTombolYes,\n        yTombolYes,\n\n        xTombolNo,\n        yTombolNo;\n\n    if (lebarLayar > tinggiLayar) {\n        // TODO\n        throw new Error('belum dimplementasikan');\n    } else {\n        marginX = 5;\n        marginY = 20;\n        spasiX = 5;\n        spasiY = 10;\n\n        ukuranTombolTutupHalaman = Math.min(30, Math.round(Math.min(lebarLayar, tinggiLayar) * 0.15));\n\n        lebarHalaman = Math.floor(lebarLayar * 0.895);\n        tinggiHalaman = Math.floor(tinggiLayar * 0.895);\n        xHalaman = Math.floor(lebarLayar * 0.055);\n        yHalaman = Math.floor(tinggiLayar * 0.080);\n\n        ukuranTeks = __tema.teks('ukuranHuruf');\n        lebarTeks = Math.floor(lebarHalaman * 0.94);\n        xTeks = Math.floor(lebarHalaman * 0.03);\n        yTeks = xTeks;\n\n        lebarTombol = Math.floor(lebarHalaman * 0.20);\n        tinggiTombol = Math.floor(tinggiHalaman * 0.10);\n\n        xTombolYes = Math.floor(lebarHalaman * 0.10); // right\n        yTombolYes = Math.floor(tinggiHalaman * 0.05); // bottom\n\n        xTombolNo = Math.floor(lebarHalaman * 0.10); // left\n        yTombolNo = yTombolYes;\n    }\n\n    return {\n        lebarLayar,\n        tinggiLayar,\n\n        marginX,\n        marginY,\n        spasiX,\n        spasiY,\n\n        lebarHalaman,\n        tinggiHalaman,\n        xHalaman,\n        yHalaman,\n\n        ukuranTombolTutupHalaman,\n\n        ukuranTeks,\n        lebarTeks,\n        xTeks,\n        yTeks,\n\n        lebarTombol,\n        tinggiTombol,\n\n        xTombolYes,\n        yTombolYes,\n\n        xTombolNo,\n        yTombolNo,\n    };\n}\n\n\n\nfunction fAturTataLetakPotret(lebarLayar, tinggiLayar) {\n    mLog.jejak('mengatur tata letak potret halaman konfig-notifikasi');\n\n    fInisiasi(lebarLayar, tinggiLayar);\n    fAturTema(lebarLayar, tinggiLayar);\n\n    const tl = fHitungUkuran(lebarLayar, tinggiLayar);\n\n    const tlTombolTutupHalaman = fHitungTataLetakTombolTutupHalaman(tl);\n\n    tombolTutupHalaman.aturDimensi(tlTombolTutupHalaman.dimensi.lebar, tlTombolTutupHalaman.dimensi.tinggi);\n    tombolTutupHalaman.aturPosisi(tlTombolTutupHalaman.posisi.x, tlTombolTutupHalaman.posisi.y);\n\n    fBuatHalaman(tl);\n}\n\n\n\n\nfunction fAturTataLetakLanskap(lebarLayar, tinggiLayar) {\n    mLog.jejak('mengatur tata letak lanskap halaman konfig-notifikasi');\n    // TODO\n    throw new Error('belum dimplementasikan');\n}\n\n\n\n\n__ekspor('aturTataLetak', (lebarLayar, tinggiLayar) => {\n    if (lebarLayar >= tinggiLayar) {\n        fAturTataLetakLanskap(lebarLayar, tinggiLayar);\n    } else {\n        fAturTataLetakPotret(lebarLayar, tinggiLayar);\n    }\n});\n"}, "lotre-1H": {"halaman/lotre-1H/indeks.css": "{{el}} {\n\n}\n", "halaman/lotre-1H/indeks.html": "\n<div id=\"tutup_halaman\"></div>\n", "halaman/lotre-1H/indeks.js": "const log = __impor('modul/0log');\n\n\nlog.info('memuat halaman lotre-1H');\n", "halaman/lotre-1H/tata_letak.js": "const mLog = __impor('modul/0log');\n\nconst mTombolTutupHalaman = __impor('modul/0tombol.tutup_halaman');\n\nconst tombolTutupHalaman = mTombolTutupHalaman.buat();\n\n\n\nconst mKreditTidakCukup = __impor('modul/kredit_tidak_cukup');\n\n\n\n\nfunction hoursToNextDay() {\n  // 1. Get the current date and time\n  const now = new Date();\n\n  // 2. Create a date object for the start of the next day (midnight)\n  const nextDay = new Date(now);\n  nextDay.setDate(now.getDate() + 1); // Increment the day\n  nextDay.setHours(0, 0, 0, 0); // Set time to midnight (00:00:00.000)\n\n  // 3. Calculate the difference in milliseconds\n  const diffInMilliseconds = nextDay.getTime() - now.getTime(); //\n\n  // 4. Convert the milliseconds difference to hours\n  // There are 1000 ms per second, 60 seconds per minute, 60 minutes per hour.\n  const hours = diffInMilliseconds / (1000 * 60 * 60);\n\n  // Return the number of hours (can be a floating-point number)\n  return Math.floor(hours);\n}\n\n\n\n\nfunction fPutaranSaatIni() {\n    const d = new Date(__tanggal());\n    const t = d.getFullYear();\n    const b = d.getMonth() + 1;\n    const h = d.getDate();\n    return `${h}/${b}/${t}`;\n}\n\n\n\n\nfunction fAturTrei(lebarLayar, tinggiLayar) {\n    const gambarTreiAtas = __impor('aset/gambar/trei-atas-2.png');\n    const gambarTreiTengah1 = __impor('aset/gambar/trei-tengah-1.png');\n    const gambarTreiTengah2 = __impor('aset/gambar/trei-tengah-2.png');\n    const gambarTreiBawah = __impor('aset/gambar/trei-bawah-2.png');\n\n    const elTrei = document.createElement('div');\n    elTrei.style.position = 'absolute';\n    elTrei.style.top = '0';\n    elTrei.style.left = '0';\n    elTrei.style.width = '100%';\n    elTrei.style.height = '100%';\n    elTrei.style.margin = '0';\n    elTrei.style.padding = '0';\n\n    const elTreiAtas = document.createElement('img');\n    elTreiAtas.src = `data:image/png;base64,${gambarTreiAtas}`;\n    elTreiAtas.style.display = 'block'