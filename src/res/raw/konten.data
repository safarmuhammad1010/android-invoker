impan('hal_market-hal_sekarang', vHalSekarang);\n    fKeHalaman(vHalSekarang);\n}\n\n\nfunction fAturKonter(lebarLayar, tinggiLayar, lebarTombol, tinggiTombol, spasi) {\n    const lebarKontener = (lebarTombol * 2) + spasi;\n\n    const elKontener = document.createElement('div');\n    elKontener.style.position = 'absolute';\n    elKontener.style.width = parseInt(lebarKontener) + 'px';\n    elKontener.style.height = tinggiTombol + 'px';\n    elKontener.style.bottom = Math.floor(tinggiLayar * 0.020) + 'px';\n    elKontener.style.left = Math.floor(lebarLayar * 0.05) + 'px';\n    __el.appendChild(elKontener);\n\n    const gambarKonter = __impor('aset/gambar/latar-konter.png');\n    const elKonter = document.createElement('img');\n    elKonter.src = `data:image/png;base64,${gambarKonter}`;\n    elKonter.style.position = 'absolute';\n    elKonter.style.width = '100%';\n    elKonter.style.height = '100%';\n    elKontener.appendChild(elKonter);\n\n    const xTeks1 = Math.floor(lebarTombol * 0.20);\n    const yTeks1 = Math.floor(tinggiTombol * 0.30);\n    const xTeks2 = xTeks1;\n    const yTeks2 = yTeks1;\n    const ukuranHuruf = Math.floor(tinggiTombol * 0.42);\n\n    const elHalSekarang = document.createElement('div');\n    elHalSekarang.style.position = 'absolute';\n    elHalSekarang.style.color = __tema.warna('sekunder');\n    elHalSekarang.style.opacity = '0.3';\n    elHalSekarang.style.fontFamily = __tema.teks('varianHuruf');\n    elHalSekarang.style.fontSize = ukuranHuruf + 'px';\n    elHalSekarang.style.userSelect = 'none';\n    elHalSekarang.style.left = xTeks1 + 'px';\n    elHalSekarang.style.top = yTeks1 + 'px';\n    elHalSekarang.innerHTML = '' + vHalSekarang;\n    elKontener.appendChild(elHalSekarang);\n\n    const elHalTotal = document.createElement('div');\n    elHalTotal.style.position = 'absolute';\n    elHalTotal.style.color = __tema.warna('sekunder')\n    elHalTotal.style.opacity = '0.3';\n    elHalTotal.style.fontFamily = __tema.teks('varianHuruf');\n    elHalTotal.style.fontSize = ukuranHuruf + 'px';\n    elHalTotal.style.userSelect = 'none';\n    elHalTotal.style.right = xTeks2 + 'px';\n    elHalTotal.style.top = yTeks2 + 'px';\n    elHalTotal.innerHTML = '' + vHalTotal;\n    elKontener.appendChild(elHalTotal);\n\n    function perbaruiKonterSekarang(halSekarang) {\n        elHalSekarang.innerHTML = '' + halSekarang;\n    }\n    function perbaruiKonterTotal(halTotal) {\n        elHalTotal.innerHTML = '' + halTotal;\n    }\n    perbaruiKonterSekarang(vHalSekarang);\n    perbaruiKonterTotal(vHalTotal);\n\n    __data.pantau('hal_market-hal_sekarang', (_, halSekarang) => {\n        perbaruiKonterSekarang(halSekarang);\n    });\n    __data.pantau('hal_market-hal_total', (_, halTotal) => {\n        perbaruiKonterTotal(halTotal);\n    });\n}\n\n\nfunction fAturTombol(lebarLayar, tinggiLayar, lebarTombol, tinggiTombol, spasi) {\n    const gambarTombolMundur1 = __impor('aset/gambar/tombol-mundur-1.png');\n    const gambarTombolMundur2 = __impor('aset/gambar/tombol-mundur-2.png');\n    const gambarTombolMaju1 = __impor('aset/gambar/tombol-maju-1.png');\n    const gambarTombolMaju2 = __impor('aset/gambar/tombol-maju-2.png');\n\n    const srcTombolMundurNormal = `data:image/png;base64,${gambarTombolMundur1}`;\n    const srcTombolMundurDitekan = `data:image/png;base64,${gambarTombolMundur2}`;\n    const srcTombolMundurNonaktif = `data:image/png;base64,${gambarTombolMundur2}`;\n\n    const srcTombolMajuNormal = `data:image/png;base64,${gambarTombolMaju1}`;\n    const srcTombolMajuDitekan = `data:image/png;base64,${gambarTombolMaju2}`;\n    const srcTombolMajuNonaktif = `data:image/png;base64,${gambarTombolMaju2}`;\n\n    const xMundur = Math.floor(lebarLayar * 0.05) + (lebarTombol * 2 + spasi) + spasi;\n\n    const elTombolMundur = document.createElement('img');\n    elTombolMundur.src = (vHalSekarang > 1) ? srcTombolMundurNormal : srcTombolMundurNonaktif;\n    elTombolMundur.style.position = 'absolute';\n    elTombolMundur.style