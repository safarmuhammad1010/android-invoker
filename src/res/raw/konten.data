}\n\n\n\n\nfunction fAturTataLetakPotret(lebarLayar, tinggiLayar) {\n    mLog.jejak('mengatur tata letak potret halaman konfig-notifikasi');\n\n    fInisiasi(lebarLayar, tinggiLayar);\n    fAturTema(lebarLayar, tinggiLayar);\n\n    const tl = fHitungUkuran(lebarLayar, tinggiLayar);\n\n    const tlTombolTutupHalaman = fHitungTataLetakTombolTutupHalaman(tl);\n\n    tombolTutupHalaman.aturDimensi(tlTombolTutupHalaman.dimensi.lebar, tlTombolTutupHalaman.dimensi.tinggi);\n    tombolTutupHalaman.aturPosisi(tlTombolTutupHalaman.posisi.x, tlTombolTutupHalaman.posisi.y);\n\n    fBuatHalaman(tl);\n}\n\n\n\n\nfunction fAturTataLetakLanskap(lebarLayar, tinggiLayar) {\n    mLog.jejak('mengatur tata letak lanskap halaman konfig-notifikasi');\n    // TODO\n    throw new Error('belum dimplementasikan');\n}\n\n\n\n\n__ekspor('aturTataLetak', (lebarLayar, tinggiLayar) => {\n    if (lebarLayar >= tinggiLayar) {\n        fAturTataLetakLanskap(lebarLayar, tinggiLayar);\n    } else {\n        fAturTataLetakPotret(lebarLayar, tinggiLayar);\n    }\n});\n"}, "lotre-1B": {"halaman/lotre-1B/indeks.css": "{{el}} {\n\n}\n", "halaman/lotre-1B/indeks.html": "\n<div id=\"tutup_halaman\"></div>\n", "halaman/lotre-1B/indeks.js": "const log = __impor('modul/0log');\n\n\nlog.info('memuat halaman lotre-1B');\n", "halaman/lotre-1B/tata_letak.js": "const mLog = __impor('modul/0log');\n\nconst mTombolTutupHalaman = __impor('modul/0tombol.tutup_halaman');\n\nconst tombolTutupHalaman = mTombolTutupHalaman.buat();\n\n\nconst mLoading = __impor('modul/loading');\n\n\n\nconst mKreditTidakCukup = __impor('modul/kredit_tidak_cukup');\n\n\n\nfunction hoursToNextDay() {\n  // 1. Get the current date and time\n  const now = new Date();\n\n  // 2. Create a date object for the start of the next day (midnight)\n  const nextDay = new Date(now);\n  nextDay.setDate(now.getDate() + 1); // Increment the day\n  nextDay.setHours(0, 0, 0, 0); // Set time to midnight (00:00:00.000)\n\n  // 3. Calculate the difference in milliseconds\n  const diffInMilliseconds = nextDay.getTime() - now.getTime(); //\n\n  // 4. Convert the milliseconds difference to hours\n  // There are 1000 ms per second, 60 seconds per minute, 60 minutes per hour.\n  const hours = diffInMilliseconds / (1000 * 60 * 60);\n\n  // Return the number of hours (can be a floating-point number)\n  return Math.floor(hours);\n}\n\n\n\nfunction getDaysUntilNextMonth() {\n  const today = new Date();\n  const year = today.getFullYear();\n  const month = today.getMonth(); // 0-indexed (Jan=0)\n\n  // Get the last day of the current month\n  // (Passing month + 1 with day 0 gives the last day of the current month)\n  const lastDay = new Date(year, month + 1, 0).getDate();\n\n  // Subtract current day from total days in month\n  return lastDay - today.getDate() + 1;\n}\n\n\n\n\nfunction fCekLotreBulanan() {\n    const x1 = __data.ambil('lotre_1B-ikut');\n    if (!x1) return false;\n\n    const d1 = new Date(x1);\n    const b1 = d1.getMonth();\n    const t1 = d1.getFullYear();\n\n    const d2 = new Date();\n    const b2 = d2.getMonth();\n    const t2 = d2.getFullYear();\n\n    return (b1 === b2) && (t1 == t2);\n}\n\n\n\n\n\nfunction fAturTrei(lebarLayar, tinggiLayar) {\n    const gambarTreiAtas = __impor('aset/gambar/trei-atas-2.png');\n    const gambarTreiTengah1 = __impor('aset/gambar/trei-tengah-1.png');\n    const gambarTreiTengah2 = __impor('aset/gambar/trei-tengah-2.png');\n    const gambarTreiBawah = __impor('aset/gambar/trei-bawah-2.png');\n\n    const elTrei = document.createElement('div');\n    elTrei.style.position = 'absolute';\n    elTrei.style.top = '0';\n    elTrei.style.left = '0';\n    elTrei.style.width = '100%';\n    elTrei.style.height = '100%';\n    elTrei.style.margin = '0';\n    elTrei.style.padding = '0';\n\n    const elTreiAtas = document.createElement('img');\n    elTreiAtas.src = `data:image/png;base64,${gambarTreiAtas}`;\n    elTreiAtas.style.display = 'block';\n    elTreiAtas.style.width = '100%';\n    elTre