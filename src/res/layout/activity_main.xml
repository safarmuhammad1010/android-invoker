<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <WebView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/webview"/>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/loading">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:id="@+id/latar_loading"
            android:src="@drawable/latar_loading"
            android:scaleType="fitXY"/>

        <ImageView
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:id="@+id/ikon_loading_1"
            android:src="@drawable/ikon_loading_1"
            android:layout_centerInParent="true"/>

        <ImageView
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:id="@+id/ikon_loading_2"
            android:src="@drawable/ikon_loading_2"
            android:layout_centerInParent="true"/>

        <ImageView
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:id="@+id/ikon_loading_3"
            android:src="@drawable/ikon_loading_3"
            android:layout_centerInParent="true"/>

        <ImageView
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:id="@+id/ikon_loading_4"
            android:src="@drawable/ikon_loading_4"
            android:layout_centerInParent="true"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/teks_loading"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"
            android:gravity="center_horizontal"
            android:paddingHorizontal="6dp"
            android:paddingBottom="4dp"
            android:textSize="14dp"
            android:textColor="#ffffff"
            android:alpha="0.2"
            android:text="[i] Sedang mengunduh data dari server. Lamanya proses ini bergantung pada kecepatan koneksi internet anda."
            android:visibility="gone"/>

    </RelativeLayout>

</FrameLayout>
